+	if (feature_incompat & 0x0004) { // EXT3_FEATURE_INCOMPAT_RECOVER
+		fs_type = "ext3";
+	}
+	if (feature_incompat & 0x0040) { // EXT4_FEATURE_INCOMPAT_EXTENTS
+		fs_type = "ext4";
+	}
