+			ri.got_max = s->offset + s->size;
+			ri.got_va = s->rva;
+		}
+		if (!strcmp (s->name, ".plt")) {
+			ri.plt_min = s->offset;
+			ri.plt_max = s->offset + s->size;
+			ri.plt_va = s->rva;
+			ri.plt = true;
+		}
+		if (ri.got && ri.plt) {
+			break;
+		}
+	}
+	if (!ri.got || !ri.plt) {
+		return false;
+	}
+	ut64 baddr = eo->user_baddr; // 0x10000;
