+            break; /* fall through to default */
+        case tagValidationType:
+            if (value < validationTypeTableSize) {
+                printf("%s\n", validationTypeTable[value]);
+                return;
+            }
+            break; /* fall through to default */
+        default:
+            break;
+    }
+    printf("%ld\n", value);
+}
