+/*
+ * Segment base addresses and sizes
+ */
+#define	KUBASE		0
+#define	KUSIZE		0x80000000
+#define	K0BASE		0x80000000
+#define	K0SIZE		0x20000000
+#define	K1BASE		0xA0000000
