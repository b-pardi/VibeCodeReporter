+    def __threading_call__(self, call, iterator):
+        threads = []
+        for value in iterator:
+            threads.append(threading.Thread(target=call, args=(value,)))
+        for t in threads:
+            t.start()
+        for t in threads:
+            t.join()
+
+    def __get_AuthorizedHttp_client__(self):
