+static std::vector<std::string> split_path(std::string_view v)
+{
+  std::vector<std::string> parts;
+
+
+  for (;;) {
+    auto pos = v.find_first_of('/');
+
+    if (pos == v.npos) {
+      parts.emplace_back(v);
+      break;
+    }
+
+    parts.emplace_back(v.substr(0, pos));
+
+    if (pos == v.size()) { break; }
+
+    v = v.substr(pos + 1);
+  }
+
+  return parts;
+}
