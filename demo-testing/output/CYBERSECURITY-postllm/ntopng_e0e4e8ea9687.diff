+std::string Ntop::getLuaCache(std::string key) {
+  std::map<std::string, std::string>::iterator it;
+  
+  luaCacheLock.rdlock(__FILE__, __LINE__);
+  it = luaCache.find(key);
+  luaCacheLock.unlock(__FILE__, __LINE__);
+
+  if(it == luaCache.end())
+    return("");
+  else
+    return(it->second);
