+		// eprintf ("%d\n", r_str_nlen (str2, len));
+		return r_str_ndup ((const char *)str3, sizeof (str3));
+	}
+	R_LOG_WARN ("TRUNCATED (%s)", str3);
+	return r_str_ndup ((const char *)str3, sizeof (str3));
