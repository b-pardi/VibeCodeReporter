+static const char *get_syscall_name(ut32 hash) {
+	int i;
+	for (i = 0; solana_syscalls[i].name; i++) {
+		if (solana_syscalls[i].hash == hash) {
+			return solana_syscalls[i].name;
+		}
+	}
+	return NULL;
+}
