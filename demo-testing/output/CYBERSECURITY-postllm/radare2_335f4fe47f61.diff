+static int get_capstone_mode(RArchSession *as) {
+	int mode = R_ARCH_CONFIG_IS_BIG_ENDIAN (as->config)
+		? CS_MODE_BIG_ENDIAN: CS_MODE_LITTLE_ENDIAN;
+	// sBPF is always extended mode (64-bit)
+	mode |= CS_MODE_BPF_EXTENDED;
+	return mode;
+}
