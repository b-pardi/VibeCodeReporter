+static int elf_flags_to_section_perms(int flags) {
+	int perm = 0;
+	if (R_BIN_ELF_SCN_IS_EXECUTABLE (flags)) {
+		perm |= R_PERM_X;
+	}
+	if (R_BIN_ELF_SCN_IS_WRITABLE (flags)) {
+		perm |= R_PERM_W;
+	}
+	if (R_BIN_ELF_SCN_IS_READABLE (flags)) {
+		perm |= R_PERM_R;
+	}
+	return perm;
+}
