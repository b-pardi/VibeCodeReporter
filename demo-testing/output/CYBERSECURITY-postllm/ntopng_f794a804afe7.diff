+JobQueue::JobQueue() {
+  max_num_jobs = MAX_NUM_CONCURRENT_JOBS;
+  job_id = 0;
+}
+
+/* ******************************* */
+
+JobQueue::~JobQueue() {
+  for(std::map<u_int32_t /* id */, std::pair<FILE*, std::string> >::iterator it = running_jobs.begin(); it != running_jobs.end(); ++it) {
+    if(it != running_jobs.end())
+      fclose(it->second.first);
+  }
+}
