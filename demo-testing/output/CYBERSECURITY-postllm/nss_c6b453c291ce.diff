+    *outlen = inlen;
+    if (maxout < inlen) {
+        PORT_SetError(SEC_ERROR_OUTPUT_LEN);
+        return SECFailure;
+    }
+
+    if (bufBytes) {
+        unsigned int needed = PR_MIN(bufBytes, inlen);
+        gcm_ctr_xor(outbuf, inbuf, ctr->buffer + ctr->bufPtr, needed);
+        ctr->bufPtr += needed;
+        outbuf += needed;
+        inbuf += needed;
+        inlen -= needed;
+        PORT_Assert(inlen == 0 || ctr->bufPtr == AES_BLOCK_SIZE);
+    }
+    while (inlen >= AES_BLOCK_SIZE) {
