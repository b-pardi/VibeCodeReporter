+struct frags4_key {
+	ipv4_addr_t src;
+	ipv4_addr_t dst;
+	__u16 id;
+	__u16 offset;
+};
+
+#define MAX_FRAG 1504 /* requires multiple of 8 */
+
+struct frags4_value {
+	__u16 more_frags:1;
+	__u16 len;
+	__u32 __pad;
+	char data[MAX_FRAG];
+};
