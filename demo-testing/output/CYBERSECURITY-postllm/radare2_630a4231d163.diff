+
+// R2_590 Move into libr/util/ubase64
+static inline ut64 b36_tonum(const char *s) {
+	ut64 n = 0;
+	int pos = 0;
+	if (r_str_startswith (s, "0_")) {
+		s += 2;
+	}
+	while (true) {
+		int idx = index36 [(unsigned char )*s];
+		if (idx < 0) {
+			break;
+		}
+		n += pow36[pos] * idx;
+		pos++;
+		s++;
+	}
+	return n;
+}
