+
+export const RiskSeverityChart = ({
+  critical,
+  high,
+  medium,
+  low,
+  informational,
+}: RiskSeverityChartProps) => {
+  // Calculate total findings
+  const totalFindings = critical + high + medium + low + informational;
+
+  // Transform data to BarDataPoint format
+  const chartData: BarDataPoint[] = [
