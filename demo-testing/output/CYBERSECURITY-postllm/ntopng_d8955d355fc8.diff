+  ndpi_serialize_string_uint32(&device_json, "devtype", device_type);
+
+  json_str = ndpi_serializer_get_buffer(&device_json, &json_str_len);
+
+  if((json_str != NULL) && (json_str_len > 0)) {
+    char key[64];
