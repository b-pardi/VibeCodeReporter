+@pwndbg.lib.memoize.reset_on_start
+def kcmdline() -> str:
+    cmdline_addr = pwndbg.gdblib.memory.pvoid(pwndbg.gdblib.symbol.address("saved_command_line"))
+    return pwndbg.gdblib.memory.string(cmdline_addr).decode("ascii")
+
