+	int l = 0;
+	int pp = 0; // no prefix
+	int opcode;
+	const Operand *vvvv_op;
+	const Operand *rm_op;
+	if (!strcmp (op->mnemonic, "andn")) {
+		opcode = 0xf2;
+		vvvv_op = src1;
+		rm_op = src2;
+	} else if (!strcmp (op->mnemonic, "bextr")) {
+		opcode = 0xf7;
+		vvvv_op = src2;
+		rm_op = src1;
+	} else {
