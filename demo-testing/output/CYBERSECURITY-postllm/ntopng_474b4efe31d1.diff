+
+void NetworkInterface::getActiveMacs(lua_State *vm) {
+  struct LuaArrayEntryStats s;
+  u_int32_t begin_slot = 0;
+
+  lua_newtable(vm);
+  
+  s.vm = vm, s.num = 0;
+  walker(&begin_slot, true /* walk_all */, walker_macs,
+	 active_mac_search_walker, (void *)&s);
+}