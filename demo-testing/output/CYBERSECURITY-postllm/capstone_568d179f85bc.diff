+def num2prefix_hex(x, prefix="#"):
+    if x.startswith("0x") or x.startswith("-0x") or x == "0":
+        x = prefix + x
+    if x.isdigit() or (x.startswith("-") and x[1:].isdigit()):
+        x = prefix + hex(int(x))
+    return x
+
+def op2prefix_hex(x):
+    x = num2prefix_hex(x)
