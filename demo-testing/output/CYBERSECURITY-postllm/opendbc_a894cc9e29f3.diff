+  if (address == 0xDE) {  // EPS_1
+    return crc ^ 0x10;
+  } else if (address == 0x106) {  // EPS_2
+    return crc ^ 0xF6;
+  } else if (address == 0x122) {  // EPS_3
+    return crc ^ 0xF1;
+  } else {
+    return crc ^ 0xA;
+  }
