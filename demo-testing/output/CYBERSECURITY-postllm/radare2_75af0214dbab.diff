+// Parse an immediate value. Accept optional leading '#' and hex (0x) or decimal.
+static int parse_immediate_token(const char *token, int *out_val) {
+	const char *p = token;
+	if (*p == '#') {
+		p++;
+	}
+	if (*p == '\0') {
+		return 0;
+	}
+	char *endptr = NULL;
+	long val = strtol (p, &endptr, 0);
+	if (endptr == p) {
+		return 0;
+	}
+	*out_val = (int)val;
+	return 1;
+}
