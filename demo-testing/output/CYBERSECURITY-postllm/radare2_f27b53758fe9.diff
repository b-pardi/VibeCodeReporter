+/* extract extension part of a file / (if no extension, return pointer to end-of-string) */
 R_API char *tcc_fileextension(const char *name) {
 	char *b = tcc_basename (name);
 	char *e = strrchr (b, '.');
 	return e? e: strchr (b, 0);
 }
 
