+R_API const char *r_log_level_tocolor(int level) {
+	const char *k = Color_YELLOW;
+	switch (level) {
+	case R_LOG_LEVEL_FATAL:
+	case R_LOG_LEVEL_ERROR:
+		k = Color_RED;
+		break;
+	case R_LOG_LEVEL_INFO:
+		k = Color_YELLOW;
+		break;
+	case R_LOG_LEVEL_WARN:
+		k = Color_MAGENTA;
+		break;
+	case R_LOG_LEVEL_DEBUG:
+		k = Color_GREEN;
+		break;
+	default:
+		break;
+	}
+	return k;
+}
