+def file_block(x: io.StringIO, filename: str) -> io.StringIO:
+    out = io.StringIO()
+    out.write(f"\n/** begin: {filename} **/\n")
+    out.write(x.read().strip())
+    out.write(f"\n/** end: {filename} **/\n")
+    out.seek(0)
+    return out
