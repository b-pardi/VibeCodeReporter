+def add_static_to_fns(x: io.StringIO) -> io.StringIO:
+    out = io.StringIO()
+    depth = 0
+    for line in x.readlines():
+        tokens = line.split()
+        # assumes return type starts on column 0
+        if depth == 0 and any(
+            line.startswith(typ) for typ in ["void", "uint32_t", "int16_t", "int"]
+        ):
+            out.write("static " + line)
+        else:
+            out.write(line)
+        if "{" in line:
+            depth += 1
+        if "}" in line:
+            depth -= 1
+    out.seek(0)
+    return out
+
