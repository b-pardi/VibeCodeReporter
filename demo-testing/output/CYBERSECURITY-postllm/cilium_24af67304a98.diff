+
+    pktgen__init(&builder, ctx);
+
+    l4 = pktgen__push_ipv6_tcp_packet(&builder,
+				      (__u8 *)src, (__u8 *)dst,
+				      (__u8 *)POD_IPV6, (__u8 *)SERVICE_IPV6,
+				      sport, tcp_svc_one);
+    if (!l4)
+	return TEST_ERROR;
+
+    data = pktgen__push_data(&builder, default_data, sizeof(default_data));
+    if (!data)
+	return TEST_ERROR;
+
+    pktgen__finish(&builder);
+    return 0;
