+    auto x = cookie->protocol;
+    if ( ! x || ! x->analyzer )
+        return false;
+
+    auto* tcp = dynamic_cast<zeek::analyzer::tcp::TCP_ApplicationAnalyzer*>(x->analyzer);
+    if ( ! tcp )
+        return false;
+
