+#ifndef BAREOS_STORED_BACKENDS_DEDUP_VOLUME_H_
+#define BAREOS_STORED_BACKENDS_DEDUP_VOLUME_H_
+
+namespace dedup {
+class volume {
+ public:
+  enum open_type
+  {
+    ReadWrite,
+    ReadOnly
+  };
+
+  volume(open_type type,
+         int creation_mode,
+         const char* path,
+         std::size_t blocksize)
+      : sys_path{path}
+  {
+    (void)type;
+    (void)creation_mode;
+    (void)blocksize;
+  }
+  const char* path() const { return sys_path.c_str(); }
+
+  int fileno() const { return fd; }
+
+ private:
+  std::string sys_path;
+  int fd;
+};
+};  // namespace dedup
+
+#endif  // BAREOS_STORED_BACKENDS_DEDUP_VOLUME_H_




