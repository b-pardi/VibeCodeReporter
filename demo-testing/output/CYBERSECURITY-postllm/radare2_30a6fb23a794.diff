+		ut8 rex = 0x48; // REX.W
+		if (dst->extended) rex |= 0x01; // B for r/m field
+		data[l++] = rex;
+	} else if (dst->extended) {
+		data[l++] = 0x41; // REX.B for r/m field extension
+	}
