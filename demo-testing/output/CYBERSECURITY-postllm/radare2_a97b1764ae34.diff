+	if (fd == -1) {
+		return NULL;
+	}
+	ut8 *buf = NULL;
+	size_t size = 0;
+	size_t capacity = 4096;
+	buf = malloc (capacity);
+	if (!buf) {
+		close (fd);
+		return NULL;
+	}
+	while (true) {
+		ssize_t r = read (fd, buf + size, capacity - size);
+		if (r < 0) {
+			// read error
+			free (buf);
+			close (fd);
+			return NULL;
+		}
+		if (r == 0) {
+			// EOF
+			break;
+		}
+		size += r;
+		if (size >= capacity) {
+			// grow buffer
+			capacity *= 2;
+			ut8 *nbuf = realloc (buf, capacity);
+			if (!nbuf) {
+				free (buf);
+				close (fd);
+				return NULL;
+			}
+			buf = nbuf;
+		}
+	}
+	close (fd);
+	*sz = size;
+	return buf;
+}
