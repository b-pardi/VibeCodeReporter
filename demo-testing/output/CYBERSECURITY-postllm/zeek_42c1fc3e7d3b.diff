+def read_plugin_version(plugin_dir: pathlib.Path):
+    """
+    Open the VERSION file, look for the first non empty
+    non comment line and return it.
+    """
+    with (plugin_dir / "VERSION").open() as f:
+        for line in f:
+            line = line.strip()
+            if line and not line.startswith("#"):
+                return line
+    return ""
