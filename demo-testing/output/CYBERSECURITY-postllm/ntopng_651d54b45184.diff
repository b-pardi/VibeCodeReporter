+
+bool Ntop::viewHasZMQInterface(NetworkInterface *viewInterface) {
+#ifdef NTOPNG_PRO
+  for(int i = 0; i < num_defined_interfaces; i++) {
+    if(iface[i]
+       && (iface[i]->viewedBy() == viewInterface)
+       && (iface[i]->getIfType() == interface_type_ZMQ)
+       )
+      return(true);
+  }
+#endif
+
+  return(false);
+}