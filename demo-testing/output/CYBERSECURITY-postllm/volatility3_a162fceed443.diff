+class TestLinuxVolshell:
+    def test_linux_volshell(self, image, volatility, python):
+        out = test_volatility.basic_volshell_test(
+            image, volatility, python, globalargs=("-l",)
+        )
+        assert out.count(b"<task_struct") > 100
+
