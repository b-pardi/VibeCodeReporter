+def current_time_ns():
+    """
+    unified function to return current time in ns
+    time.time_ns() exist since python 3.7 when no more supported
+    remove this function.
+    """
+    try:
+        return time.time_ns()
+    except AttributeError:
+        return convert_to_ns(time.time())
