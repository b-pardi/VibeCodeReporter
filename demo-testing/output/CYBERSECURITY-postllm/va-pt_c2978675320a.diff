+def _decode_cdp_caps(val_bytes):
+    if len(val_bytes) < 4:
+        return None, None
+    bm = struct.unpack("!I", val_bytes[:4])[0]
+    caps = [name for bit, name in CDP_CAP_BITS.items() if bm & bit]
+    return bm, caps
+
