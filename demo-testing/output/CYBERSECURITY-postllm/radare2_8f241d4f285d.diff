+static const ut8 *data16_form_value(entry_descriptor desc, const ut8 *buf, const ut8 *buf_end, ut8 val[16]) {
+	if (desc.form != DW_FORM_data16) {
+		R_LOG_DEBUG ("Expected form type data16 but got: %#x", desc.form);
+		return NULL;
+	}
+	if (buf + 16 >= buf_end) {
+		return NULL;
+	}
+
+	memcpy (val, buf, 16);
+	buf += 16;
+