+static size_t buf_format_size(const char *fmt) {
+	size_t res = 0;
+	int i;
+	int m = 1;
+	int tsize = 2;
+
+	for (i = 0; fmt[i]; i++) {
+		switch (fmt[i]) {
+		case '0':
+		case '1':
+		case '2':
+		case '3':
+		case '4':
+		case '5':
+		case '6':
+		case '7':
+		case '8':
+		case '9':
+			if (m == 1) {
+				m = atoi (fmt + i);
+			}
+			continue;
+		case 's': tsize = 2; break;
+		case 'S': tsize = 2; break;
+		case 'i': tsize = 4; break;
+		case 'I': tsize = 4; break;
+		case 'l': tsize = 8; break;
+		case 'L': tsize = 8; break;
+		case 'c': tsize = 1; break;
+		default:
+			  R_LOG_ERROR ("Invalid format");
+			  return -1;
+		}
+		if (m < 1) {
+			R_LOG_ERROR ("Invalid multiply size in format");
+			break;
+		}
+
+		res += (tsize * m);
+		m = 1;
+	}
+	return res;
+}
