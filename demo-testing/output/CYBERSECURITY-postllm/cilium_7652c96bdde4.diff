+{
+	struct policy_key key = {
+		.sec_label = sec_label,
+		.egress = egress,
+		.protocol = protocol,
+		.dport = dport,
+	};
+	struct policy_entry value = {
+		.deny = deny,
+	};
+
+	map_update_elem(&POLICY_MAP, &key, &value, BPF_ANY);
+}
