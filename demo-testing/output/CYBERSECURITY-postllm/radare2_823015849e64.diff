+static int whatbpos(const char *arg) {
+	int bpos = 0;
+	int n = 0;
+	while (*arg && *arg != ' ') {
+		if (isdigit (*arg)) {
+			n = atoi (arg);
+			if (n > 64) {
+				R_LOG_ERROR ("Too large. Max is 64");
+				return bpos;
+			}
+			while (isdigit (*arg)) {
+				arg += 1;
+			}
+			arg--;
+		} else if (*arg == '.') {
+			if (n < 1) {
+				n = 1;
+			}
+			bpos += n;
+			n = 0;
+		} else if (*arg == '+') {
+			// used to separate tokens
+			// for example 3+3:4b  -> [0..3] + [6..10]
+		} else if (*arg == 'b') {
+			bpos += n;
+			n = 0;
+		}
+		arg++;
+	}
+	return bpos;
+}
