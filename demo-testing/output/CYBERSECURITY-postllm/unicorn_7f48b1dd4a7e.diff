+            tb_exec_unlock(uc);
+        }
+        uc->cpu->tcg_exit_req = 0;
+
+        if (uc->skip_sync_pc_on_exit) {
+            cpu_loop_exit(uc->cpu);
+        } else {
+            uc->skip_sync_pc_on_exit = false;
+            cpu_loop_exit_restore(uc->cpu, GETPC());
+        }
+    }
