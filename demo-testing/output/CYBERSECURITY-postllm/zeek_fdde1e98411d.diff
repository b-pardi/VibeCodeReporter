+    success &= fmt.Write(header.filter_name, "filter_name");
+    success &= fmt.Write(header.path, "path");
+    success &= fmt.Write(static_cast<uint32_t>(header.fields.size()), "num_fields");
+    for ( const auto& f : header.fields )
