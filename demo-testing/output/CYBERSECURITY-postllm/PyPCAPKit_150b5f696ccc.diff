+
+        """
+        if not (isinstance(value, int) and 0 <= value <= 3):
+            raise ValueError('%r is not a valid %s' % (value, cls.__name__))
+        extend_enum(cls, 'Unassigned_%d' % value, value)
+        return cls(value)




