+class _SSHHeaderField(FieldListField):
+    def getfield(self, pkt, s):
+        val = []
+        while s:
+            s, v = self.field.getfield(pkt, s)
+            val.append(v)
+            if v[:4] == b"SSH-":
+                return s, val
+        return s, val
