+static std::string join(const std::vector<std::string>& x)
+{
+  std::stringstream output;
+
+  output << "[";
+
+  bool first = true;
+  for (auto& m : x) {
+    if (first) {
+      first = false;
+    } else {
+      output << ", ";
+    }
+    output << "\"" << m << "\"";
+  }
+
+  output << "]";
+
+  return output.str();
+}
