+				if (d >= MAXPSEUDOOPS) {
+					// XXX Shouldn't ever happen...
+					continue;
+				}
+				int idx = ops[i].args[d++];
+				if (idx <= 0) {
+					// XXX Shouldn't ever happen...
+					continue;
+				}
+				const char *w = argv[idx];
+				if (w) {
+					strcpy (newstr + k, w);
+					k += strlen (w) - 1;
+				}
+			} else {
+				newstr[k] = ch;
+			}
+		}
+		newstr[k] = '\0';
+		return true;
+	}
+
+	RStrBuf *sb = r_strbuf_new ("");
+	for (i = 0; i < argc; i++) {
