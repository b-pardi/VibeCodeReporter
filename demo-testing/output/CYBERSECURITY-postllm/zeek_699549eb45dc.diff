+void Specific_RE_Matcher::MatchDisjunction(const String* s, std::vector<int>& matches) {
+    auto bv = s->Bytes();
+    auto n = s->Len();
+
+    ASSERT(dfa);
+
+    DFA_State* d = dfa->StartState();
+    d = d->Xtion(ecs[SYM_BOL], dfa);
+
+    while ( d ) {
+        if ( --n < 0 )
+            break;
+
+        int ec = ecs[*(bv++)];
+        d = d->Xtion(ec, dfa);
+    }
+
+    if ( d )
+        d = d->Xtion(ecs[SYM_EOL], dfa);
+
+    if ( d )
+        if ( auto a_set = d->Accept() )
+            for ( auto a : *a_set )
+                matches.push_back(a);
+}
