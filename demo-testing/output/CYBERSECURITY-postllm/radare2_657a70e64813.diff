+R_API char *r_str_pad2(char *pad, size_t padsz, const char ch, int sz) {
+	if (pad == NULL) {
+		pad = malloc (sz + 1);
+		if (!pad) {
+			return NULL;
+		}
+	}
+	if (sz < 0) {
+		sz = 0;
+	}
+	memset (pad, ch, R_MIN (sz, sizeof (pad)));
+	if (sz < sizeof (pad)) {
+		pad[sz] = 0;
+	}
+	pad[sizeof (pad) - 1] = 0;
+	return pad;
+}
