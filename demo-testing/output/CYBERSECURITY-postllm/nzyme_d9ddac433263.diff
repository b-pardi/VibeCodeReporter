+            </h1>
+          </div>
+        </div>
+
+        <div className="row">
+          <div className="col-md-12">
+            <div className="card">
+              <div className="card-body">
+                This page will show all details about the hostname, including which DNS requests and responses
+                it appeared in and which clients/servers were involved.
+              </div>
+            </div>
+          </div>
+        </div>
+
+      </React.Fragment>
+  )
+
+}
