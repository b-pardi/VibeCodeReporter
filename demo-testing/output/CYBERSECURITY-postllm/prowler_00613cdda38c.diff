+
+	try {
+		const response = await fetch(`${keyServer}/providers`, {
+			method: "POST",
+			headers: {
+				"X-Tenant-ID": "12646005-9067-4d2a-a098-8bb378604362",
+				"Content-Type": "application/vnd.api+json",
+			},
+			body: JSON.stringify({
+				data: {
+					type: "Provider",
+					attributes: {
