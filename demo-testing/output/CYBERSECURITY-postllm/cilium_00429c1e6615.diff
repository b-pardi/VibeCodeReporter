+snat_v6_rev_nat_handle_icmp_pkt_toobig(struct __ctx_buff *ctx, __u32 off)
+{
+	struct ipv6_nat_entry *state;
+	struct ipv6_ct_tuple tuple = {};
+	struct ipv6hdr iphdr;
+	__be16 identifier;
+	__u8 type;
+	__u32 icmpoff = off;
