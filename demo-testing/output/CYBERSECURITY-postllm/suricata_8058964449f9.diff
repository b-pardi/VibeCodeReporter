+    elt.len = strlen(elt.value);
+
+    int add_ret = DatajsonAdd(set, (const uint8_t *)val, strlen(val), &elt);
+    if (add_ret < 0) {
+        FatalErrorOnInit("datajson data add failed %s/%s", set->name, set->load);
+        return 0;
+    }
+    if (add_ret == 0) {
+        SCFree(elt.value);
+    } else {
+        return 1;
+    }
+
+    return 0;
+}
