+		l4_proto = ip6->nexthdr;
+		l3_hdrlen = sizeof(struct ipv6hdr);
+		break;
+#endif
+#ifdef ENABLE_IPV4
+	case bpf_htons(ETH_P_IP):
+		if (!revalidate_data(ctx, &data, &data_end, &ip4))
+			return false;
