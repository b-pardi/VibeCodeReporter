+static __always_inline bool
+ctx_is_overlay_hdr(struct __ctx_buff *ctx, __be16 proto)
+{
+	void __maybe_unused *data;
+	void __maybe_unused *data_end;
+	struct ipv6hdr __maybe_unused *ip6;
+	struct iphdr __maybe_unused *ip4;
+	__be16 dport;
+	__u8 l4_proto;
+	int l3_hdrlen;
