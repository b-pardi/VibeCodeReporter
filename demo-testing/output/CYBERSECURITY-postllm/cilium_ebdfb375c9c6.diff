+/* Test that a health-check request to a remote backend is IPIP-encapsulated. */
+PKTGEN("tc", "l4lb_health_check_host")
+int l4lb_health_check_host_pktgen(struct __ctx_buff *ctx)
+{
+	struct pktgen builder;
+	struct tcphdr *l4;
+	struct ethhdr *l2;
+	struct iphdr *l3;
+	void *data;
