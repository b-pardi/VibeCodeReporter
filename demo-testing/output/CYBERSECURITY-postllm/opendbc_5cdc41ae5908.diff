+static uint8_t _rivian_compute_checksum(const CANPacket_t *to_push, uint8_t poly, uint8_t xor_output) {
+  int len = GET_LEN(to_push);
+
+  uint8_t crc = 0;
+  // Skip the checksum byte
+  for (int i = 1; i < len; i++) {
+    crc ^= GET_BYTE(to_push, i);
+    for (int j = 0; j < 8; j++) {
