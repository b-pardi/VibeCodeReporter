+
+#define ARP_HEADER_MIN_LEN   8
+#define ARP_HEADER_LEN       28
+#define ARP_HW_TYPE_ETHERNET 0x01
+#define ARP_PROTO_TYPE_IP    0x0800
+#define ARP_HW_SIZE          6
+#define ARP_PROTO_SIZE       4
+
+typedef struct ARPHdr_ {
+    uint16_t hw_type;
+    uint16_t proto_type;
+    uint8_t hw_size;
+    uint8_t proto_size;
+    uint16_t opcode;
+    uint8_t source_mac[6];
+    uint8_t source_ip[4];
+    uint8_t dest_mac[6];
+    uint8_t dest_ip[4