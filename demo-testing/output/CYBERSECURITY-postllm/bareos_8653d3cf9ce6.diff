+struct Encoder {
+  /* we use this construct because designated initializers are not
+   * available in c++ */
+  char table[256] = {};
+
+  Encoder()
+  {
+    table['!'] = '0';
+    table['<'] = '1';
+    table['>'] = '2';
+    table[':'] = '3';
+    table['"'] = '4';
+    table['|'] = '5';
+    table['?'] = '6';
+    table['*'] = '7';
+    table[' '] = '8';
+    table['.'] = '9';
+  }
+};
+
+static Encoder enc;
