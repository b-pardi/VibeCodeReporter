+   * in a similar way; just translate it like so:
+   *    # <-> #00
+   * \xXY <-> #XY
+   * or even better:
+   *    # <-> #0
+   * \x0Y <-> #('A' + Y)
+   * \x1Y <-> #('a' + Y)
+   */
+
+  bool inside_root = p.size() >= 2 && p[1] == ':';
+  for (wchar_t c : p) {
+    switch (c) {
+      case '.':
+        [[fallthrough]];
+      case '!':
+        [[fallthrough]];
+      case '<':
+        [[fallthrough]];
+      case '>':
+        [[fallthrough]];
+      case ':':
+        [[fallthrough]];
+      case '"':
+        [[fallthrough]];
+      case '|':
+        [[fallthrough]];
+      case '?':
+        [[fallthrough]];
+      case '*':
+        [[fallthrough]];
+      case ' ': {
+        // escape special characters, but not at the root of the path
+        if (inside_root) {
+          str += c;
+        } else {
+          str += '!';
+          str += enc.table[c];
+        }
+      } break;
+      case '/':
+        [[fallthrough]];
+      case '\\': {
+        inside_root = false;
+        str += c;
+      } break;
+      default: {
+        str += c;
+      }
+    }
+  }
+
+  return str;
+}
