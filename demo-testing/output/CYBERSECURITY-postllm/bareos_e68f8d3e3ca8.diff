+    def _check_io_process(self):
+        ret = self.io_process.poll()
+        if ret is None or ret == 0:
+            return True  # still running
+
+        bareosfd.JobMessage(
+            bareosfd.M_FATAL,
+            f"'{' '.join(self.io_process.args)}' exited with code {ret}\n",
+        )
+        return False
