+static std::string AddEscapes(std::string_view src,
+                              const std::vector<char>& to_escape)
+{
+  std::string out;
+  for (char ch : src) {
+    if (std::find(to_escape.begin(), to_escape.end(), ch) != to_escape.end()) {
+      out += '\\';
+    }
+    out += ch;
+  }
+  return out;
+}
