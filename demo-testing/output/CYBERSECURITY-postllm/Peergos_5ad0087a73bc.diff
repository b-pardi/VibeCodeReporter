+    private static CompletableFuture<byte[]> readChunk(AsyncReader f, byte[] buf, int offset, int remaining) {
+        if (remaining == 0)
+            return Futures.of(buf);
+        return f.readIntoArray(buf, offset, remaining)
+                .thenCompose(read -> read == remaining ?
