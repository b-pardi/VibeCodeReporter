+#:tag:Processes
+def get_process_name(pid):
+    """Returns the process name of given pid
+
+    Args:
+        pid (int): PID of the process
+
+    Returns:
+        str: Process name
+    """
+    with open("/proc/"+str(pid)+"/comm") as f:
+        return f.read()[:-1]
