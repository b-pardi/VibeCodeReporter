+def file_sha256(filepath):
+    sha256 = hashlib.sha256()
+
+    with open(filepath, 'rb') as f:
+        while True:
+            data = f.read(1000000)
+            if not data:
+                break
+            sha256.update(data)
+
+
+
+def js_beautify_string(string):
+    if HAVE_JSBEAUTIFY:
+        string = beautify(string)
+
+    return string
+
