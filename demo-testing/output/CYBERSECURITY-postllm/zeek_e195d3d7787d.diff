+static bool compare_string_vectors(const VectorValPtr& a, const VectorValPtr& b) {
+    if ( a->Size() < b->Size() )
+        return true;
+    if ( a->Size() > b->Size() )
+        return false;
+
+    auto a_v = a->RawVec();
+    auto b_v = b->RawVec();
+
+    auto b_it = b_v.begin();
+    for ( auto a_it = a_v.begin(); a_it != a_v.end(); ++a_it, ++b_it ) {
