+		if ((src->type & OT_GPREG) && !(src->type & OT_MEMORY) && src->extended) rex |= 0x01;
+		data[l++] = rex;
+	}
+	data[l++] = 0x0f;
+	data[l++] = 0xb8;
+	if (src->type & OT_MEMORY) {
