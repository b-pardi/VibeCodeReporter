+				data[l++] = (ut8)(disp >> 16);
+				data[l++] = (ut8)(disp >> 24);
+			}
+		}
+	} else {
+		data[l++] = (ut8)(0xC0 | ((dst->reg & 7) << 3) | (src->reg & 7));
+	}
+	return l;
+}
