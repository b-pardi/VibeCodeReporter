+	// operand-size prefix for 16-bit
+	if (dst->type & OT_WORD) {
+		data[l++] = 0x66;
+	}
+	// F3 prefix is mandatory
+	data[l++] = 0xF3;
+	// REX.W for 64-bit
+	if (a->config->bits == 64 && (dst->type & OT_QWORD)) {
+		ut8 rex = 0x48; // W=1
+		if (dst->extended) rex |= 0x04; // R bit
