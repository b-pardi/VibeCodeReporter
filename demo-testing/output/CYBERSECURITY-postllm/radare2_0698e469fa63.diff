+			data[l++] = (ut8)disp;
+			data[l++] = (ut8)(disp >> 8);
+			data[l++] = (ut8)(disp >> 16);
+			data[l++] = (ut8)(disp >> 24);
+			return l;
+		}
+		if (disp != 0) {
+			mod = (disp >= -128 && disp <= 127) ? 1 : 2;
+		}
+		data[l++] = (ut8)((mod << 6) | ((dst->reg & 7) << 3) | (base & 7));
+		if (base == X86R_ESP) {
+			data[l++] = 0x24;
+		}
+		if (mod) {
+			data[l++] = (ut8)disp;
+			if (mod == 2) {
