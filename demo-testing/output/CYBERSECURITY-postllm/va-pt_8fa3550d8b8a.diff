+def find_tool_path(tool_name):
+    """
+    Locate the full path of a tool using multiple methods
+    Returns the full path if found, None otherwise
+    """
+    import shutil
+
+    # Method 1: Use shutil.which (checks PATH)
+    tool_path = shutil.which(tool_name)
+    if tool_path:
+        return tool_path
+
