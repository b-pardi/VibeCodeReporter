+    common_paths = [
+        '/usr/bin',
+        '/usr/local/bin',
+        '/opt',
+        os.path.expanduser('~/.local/bin'),
+        '/usr/share/doc'
+    ]
+
+    for base_path in common_paths:
+        try:
