+# Checks if the inferior has been terminated
+class AwaitProcessExit(QThread):
+    process_exited = pyqtSignal()
+
+    def run(self):
+        while True:
+            with debugcore.process_exited_condition:
+                debugcore.process_exited_condition.wait()
+            self.process_exited.emit()
+
