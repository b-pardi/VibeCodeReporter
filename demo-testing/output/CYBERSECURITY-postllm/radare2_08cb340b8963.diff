+static RFlagItem *get_sym_flag_at(RCore *core, ut64 addr) {
+	if (!core || !core->flags) {
+		return NULL;
+	}
+	const RList *list = r_flag_get_list (core->flags, addr);
+	if (!list) {
+		return NULL;
+	}
+	RListIter *it;
+	RFlagItem *fi;
+	r_list_foreach (list, it, fi) {
+		if (fi && fi->name && r_str_startswith (fi->name, "sym.")) {
+			return fi;
+		}
+	}
+	return NULL;
+}
