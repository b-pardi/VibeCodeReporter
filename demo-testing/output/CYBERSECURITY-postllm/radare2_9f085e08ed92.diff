+		const char *name = r_bin_name_tostring2 (sym->name, 'o');
+		if (is_entrypoint_symbol (name)) {
+			r_cons_printf ("0x%08"PFMT64x"  %s\n", sym->vaddr, name);
+		}
+	}
+	RList *bfiles = r_core_bin_files (core);
+	RBinFile *bf;
+	RListIter *objs_iter;
