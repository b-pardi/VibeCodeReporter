+       jcr->Job);
+
+  jcr->setJobStatusWithPriorityCheck(JS_Running);
+
+  Resources tmpres = jcr->dir_impl->res;
+  JobDbRecord tmpjr = jcr->dir_impl->jr;
+
+  bool returnval = ConsolidateJobs(jcr);
+
+  jcr->dir_impl->res = tmpres;
+  jcr->dir_impl->jr = tmpjr;
