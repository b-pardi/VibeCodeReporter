+	for (i = 0; i + 8 <= len; i += 8)
+		*(__u64 *)(dst + i) = *(__u64 *)(src + i);
+
+	#pragma unroll
+	for (; i < len; i++)
+		*(__u8 *)(dst + i) = *(__u8 *)(src + i);
+}
