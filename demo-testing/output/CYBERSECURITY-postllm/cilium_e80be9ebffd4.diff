+static __always_inline
+int scapy_memcmp(const void *a, const void *b, const __u16 len)
+{
+	__u32 i;
+
+	for (i = 0; i + 8 <= len; i += 8) {
+		__u64 va = *(__u64 *)(a + i);
+		__u64 vb = *(__u64 *)(b + i);
