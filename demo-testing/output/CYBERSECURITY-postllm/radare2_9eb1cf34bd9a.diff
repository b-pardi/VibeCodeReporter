+			break;
+		case DALVIK_FMT_12X:
+		case DALVIK_FMT_11N:
+			instr->f12x.a = nibble (&v[0], 0);
+			instr->f12x.b = nibble (&v[0], 1);
+			break;
+		case DALVIK_FMT_11X:
+		case DALVIK_FMT_10T:
+			instr->f11x.a = v[0];
+			break;
+		case DALVIK_FMT_20T:
+			instr->f20t.a = r_read_le16 (&v[1]);
+			break;
+		case DALVIK_FMT_22X:
+		case DALVIK_FMT_21T:
+		case DALVIK_FMT_21S:
+		case DALVIK_FMT_21H:
+		case DALVIK_FMT_21C:
+			instr->f22x.a = v[0];
+			instr->f22x.b = r_read_le16 (&v[1]);
+			break;
+		case DALVIK_FMT_23X:
+		case DALVIK_FMT_22B:
+			instr->f23x.a = v[0];
+			instr->f23x.b = v[1];
+			instr->f23x.c = v[2];
+			break;
+		case DALVIK_FMT_22T:
+		case DALVIK_FMT_22S:
+		case DALVIK_FMT_22C:
+			instr->f22t.a = nibble (&v[0], 0);
+			instr->f22t.b = nibble (&v[0], 1);
+			instr->f22t.c = r_read_le16 (&v[1]);
+			break;
+		case DALVIK_FMT_32X:
+			instr->f32x.a = r_read_le16 (&v[1]);
+			instr->f32x.b = r_read_le16 (&v[3]);
+			break;
+		case DALVIK_FMT_30T:
