+def strip_ansi_codes(s: str):
+    """
+    Strips ANSI escape codes from a string.
+    Args:
+        s (str): The string to strip.
+    Returns:
+        str: The string without ANSI escape codes.
+    """
+    ansi_escape = re.compile(r"(?:\x1B[@-_][0-?]*[ -/]*[@-~])")
+    return ansi_escape.sub("", s)
+
+
