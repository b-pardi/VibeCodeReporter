+		.license = "MIT",
+	},
+	.type = R_CRYPTO_TYPE_HASHER,
+	.implements = "sip",
+	.update = update,
+	.end = update
+};
+
+#ifndef R2_PLUGIN_INCORE
+R_API RLibStruct radare_plugin = {
+	.type = R_LIB_TYPE_CRYPTO,
