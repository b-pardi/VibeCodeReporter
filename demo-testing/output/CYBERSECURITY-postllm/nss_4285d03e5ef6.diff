+    if (desc == NULL) {
+        desc = SECOID_FindOIDTagDescription(SEC_OID_UNKNOWN);
+    }
+    SECU_Indent(out, level);
+    if (m != NULL)
+        fprintf(out, "%s\n", m);
+    fprintf(out, "%s\n", desc);
+}
