+
+#define STEP_COND 0x10000000
+#define STEP_OVER 0x20000000
+#define STEP_OUT 0x40000000
+
+// constructor
+
+#if 0
+sm510_common_disassembler_sm510_common_disassembler() {
+	// init 6-bit lfsr pc lut
+	for (ut32 i = 0, pc = 0; i < 0x3f; i++)
+	{
+		m_l2r6[i] = pc;
+		m_r2l6[pc] = i;
+		pc = increment_pc(pc, 6);
+	}
+
+	m_l2r6[0x3f] = 0x3f;
+	m_r2l6[0x3f] = 0x3f;
+
+	// init 7-bit lfsr pc lut
+	for (ut32 i = 0, pc = 0; i < 0x7f; i++)
+	{
+		m_l2r7[i] = pc;
+		m_r2l7[pc] = i;
+		pc = increment_pc(pc, 7);
+	}
+
+	m_l2r7[0x7f] = 0x7f;
+	m_r2l7[0x7f] = 0x7f;
+}
+#endif
+
+static ut64 increment_pc(ut64 pc, ut8 pclen) {
+	ut32 feed = ((pc >> 1 ^ pc) & 1) ? 0 : (1 << (pclen - 1));
+	ut32 mask = (1 << pclen) - 1;
+	return feed | (pc >> 1 & (mask >> 1)) | (pc & ~mask);
+}
