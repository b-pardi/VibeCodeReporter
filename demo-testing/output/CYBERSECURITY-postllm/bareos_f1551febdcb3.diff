+          // read/written to otherwise after making it a shared_message.
+          result ret = SendData(sd, msg, size);
+          if (ret.holds_error()) {
+            prom.set_value(std::move(ret.error_unchecked()));
+            return;
+          }
+
+          accumulated += ret.value_unchecked();
+        }
+        prom.set_value(accumulated);
+      });
