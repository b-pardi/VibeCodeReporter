+    ser_declare;
+    SerBegin(msg.data_ptr(), sizeof(comp_stream_header));
+    ser_uint32(compctx.ch.magic);
+    ser_uint32(csize);
+    ser_uint16(compctx.ch.level);
+    ser_uint16(compctx.ch.version);
+    SerEnd(msg.data_ptr(), sizeof(comp_stream_header));
+  }
