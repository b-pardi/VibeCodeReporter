+        std::size_t accumulated = 0;
+        for (;;) {
+          std::optional fut = out.get();
+          if (!fut) { break; }
+          result p = fut->get();
+          if (p.holds_error()) {
+            prom.set_value(std::move(p.error_unchecked()));
