+    25, 31, 36, 42, 50, 63, 72, 84, 102, 127, 146,
+    170, 204, 255, 292, 340, 409, 511, 584, 682, 818,
+    1023, 1169, 1364, 1637, 2047, 2340, 2730, 3276,
+    4095, 4680, 5460, 6552, 8191,
+]
+# fmt: on
+
+
+# Shorthand
+def int_size():
+    return pwndbg.aglib.typeinfo.sint.sizeof
