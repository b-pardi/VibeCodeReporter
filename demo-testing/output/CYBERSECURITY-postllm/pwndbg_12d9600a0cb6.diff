+def get_files_in_dir(directory) -> list[str]:
+    file_paths = []
+    for root, dirs, files in os.walk(directory):
+        for file in files:
+            full_path = os.path.join(root, file)
+            relative_path = os.path.relpath(full_path, directory)
+            file_paths.append(relative_path)
+    return file_paths
