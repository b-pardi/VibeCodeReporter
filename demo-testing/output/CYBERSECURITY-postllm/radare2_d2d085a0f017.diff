+		} else if (c == '/') {
+			d = 63;
+		} else {
+			return false;
+		}
+
+		/* Check for overflow */
+		if ((val >> 26) != 0) {
+			return false;
+		}
+
+		val = (val << 6) + d;
+	}
+
+	*res = val;
+	return true;
+}
