+# -- Options for the link checker ---------------------------------------
+
+linkcheck_ignore = [
+    # False positive from sphinx-build, which thinks this is a URL
+    r"^SSH::Password_Guessing",
+    # Github's anchors always 404, plus so many GH requests eventually
+    # rate-limit the checker. This should work with the option
+    # linkcheck_anchors_ignore_for_url, but it wasn't working.
+    r"^https://github\.com/.*?/.*?/blob/.*?#L\d+",
+    r"^https://github\.com/.*?/.*?/blob/.*?#L\d+-L\d+",
+    r"^https://github\.com/.*?/.*?/wiki#.*",
+    # These are an intentional redirects.
+    r"^https://zeek\.org/slack",
+    r"^https://zeek\.readthedocs\.io",
+    r"^https://zeek\.rtfd\.io",
+    # Maxmind requires logins, even though the URLs are valid. Ignore these.
+    r"^https://www\.maxmind\.com/en/.*",
+    # sphinx-build says that try.zeek.org returns a 404 for anchored links
+    # even though it shouldn't.
+    r"^https://try\.zeek\.org/#.*",
+    # This URL returns a certificate error, which it doesn't appear that
+    # we can make sphinx-build ignore.
+    r"^https://www\.eecs\.umich\.edu/techreports/cse/96/CSE-TR-316-96\.pdf",
+    # These _images paths are valid, but they're generated as part of the
+    # html builder and so they're technically invalid in the source files.
+    r"^\.\./_images/.*",
+    # This is an autogenerated file created by the html builder. There
+    # ought to be a better way to link to this than the bare HTML file.
+    r"^\.\./zeek-noticeindex.html",
+    # This consistently gets rate-limited even though we're only linking
+    # to it once in the docs. Ignore it since we know it's valid.
+    r"^https://www\.gnu\.org/software/bison/",
+]
+
+linkcheck_allowed_redirects = {
+    r"^https://docs\.zeek\.org/.*": r"https://docs\.zeek\.org/en/master/.*",
+    r"^https://docs\.zeek\.org": r"https://docs\.zeek\.org/en/master/",
+    r"^https://docs\.zeek\.org/projects/broker/.*": r"^https://docs\.zeek\.org/projects/broker/en/master/.*",
+    r"^https://docs\.zeek\.org/projects/broker": r"^https://docs\.zeek\.org/projects/broker/en/master",
+    r"^https://docs\.zeek\.org/projects/package-manager/.*": r"^https://docs\.zeek\.org/projects/package-manager/en/stable/.*",
+    r"^https://docs\.zeek\.org/projects/package-manager": r"^https://docs\.zeek\.org/projects/package-manager/en/stable",
+    r"^https://docs\.zeek\.org/projects/spicy/.*": r"^https://docs\.zeek\.org/projects/spicy/en/latest/.*",
+    r"^https://docs\.zeek\.org/projects/spicy": r"^https://docs\.zeek\.org/projects/spicy/en/latest",
+}