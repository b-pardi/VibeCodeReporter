+            if (hook->op == UC_TCG_OP_SUB && (hook->op_flags & UC_TCG_OP_FLAG_CMP)) {
+                gen_uc_traceopcode(tcg_ctx, hook, v0, v1, size, uc, pc);
+            }
+        }
+    }
