+#include <r_lib.h>
+#include "fixedint.h"
+#include "fe.h"
+
+// h = 0
+void fe_0(fe h) {
+	h[0] = 0;
+	h[1] = 0;
+	h[2] = 0;
+	h[3] = 0;
+	h[4] = 0;
+	h[5] = 0;
+	h[6] = 0;
+	h[7] = 0;
+	h[8] = 0;
+	h[9] = 0;
+}
+
+// h = 1
+void fe_1(fe h) {
+	h[0] = 1;
+	h[1] = 0;
+	h[2] = 0;
+	h[3] = 0;
+	h[4] = 0;
+	h[5] = 0;
+	h[6] = 0;
+	h[7] = 0;
+	h[8] = 0;
+	h[9] = 0;
+}
+
+/* h = f + g
+ * Can overlap h with f or g.
+ * Preconditions:
+ * 	|f| bounded by 1.1*2^25,1.1*2^24,1.1*2^25,1.1*2^24,etc.
+ * 	|g| bounded by 1.1*2^25,1.1*2^24,1.1*2^25,1.1*2^24,etc.
+ *
+ * Postconditions:
+ * |h| bounded by 1.1*2^26,1.1*2^25,1.1*2^26,1.1*2^25,etc. */
+void fe_add(fe h, const fe f, const fe g) {
+	st32 f0 = f[0];
+	st32 f1 = f[1];
+	st32 f2 = f[2];
+	st32 f3 = f[3];
+	st32 f4 = f[4];
+	st32 f5 = f[5];
+	st32 f6 = f[6];
+	st32 f7 = f[7];
+	st32 f8 = f[8];
+	st32 f9 = f[9];
+	st32 g0 = g[0];
+	st32 g1 = g[1];
+	st32 g2 = g[2];
+	st32 g3 = g[3];
+	st32 g4 = g[4];
+	st32 g5 = g[5];
+	st32 g6 = g[6];