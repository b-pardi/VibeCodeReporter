+@AutoValue
+public abstract class TimersReport {
+
+    public abstract double mean();
+    public abstract double p99();
+
+    @JsonCreator
+    public static TimersReport create(@JsonProperty("mean") double mean,
+                                      @JsonProperty("p99") double p99) {
+        return builder()
