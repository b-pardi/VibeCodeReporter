+                .p99(p99)
+                .build();
+    }
+
+    public static Builder builder() {
+        return new AutoValue_TimersReport.Builder();
+    }
+
+    @AutoValue.Builder
+    public abstract static class Builder {
+        public abstract Builder mean(double mean);
+
+        public abstract Builder p99(double p99);
+
