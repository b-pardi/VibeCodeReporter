+                                "AND created_at > :cutoff AND tap_uuid IN (<taps>)" +
+                                "GROUP BY bucket ORDER BY bucket DESC")
+                        .bind("disco_type", discoType.getNumber())
+                        .bind("cutoff", DateTime.now().minusMinutes(minutes))
