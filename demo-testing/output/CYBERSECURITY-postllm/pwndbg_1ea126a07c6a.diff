+def count_pointers(ty: Any) -> Tuple[str, int]:
+    derefcnt = 0
+    while isinstance(ty, binaryninja.types.PointerType):
+        ty = ty.target
+        derefcnt += 1
+    return (str(ty), derefcnt)
