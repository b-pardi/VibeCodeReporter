+        Boolean active = nzyme.getDatabase().withHandle(handle ->
+                handle.createQuery("SELECT active FROM health_indicators WHERE indicator_id = :indicator_id")
+                        .bind("indicator_id", indicatorId)
+                        .mapTo(Boolean.class)
+                        .first()
+        );
+
+        if (active != null) {
+            return active;
+        }
+
