+static void settxtf(EvmOp *op, const char *fmt, ...) {
+	if (strchr (fmt, '%')) {
+		va_list ap;
+		va_start (ap, fmt);
+		op->txt = op->txt_buf;
+		vsnprintf (op->txt_buf, sizeof (op->txt_buf), fmt, ap);
+		va_end (ap);
+	} else {
+		op->txt = fmt;
+	}
+}
