+/*
+ * Feedback messages
+ */
+function okMsg(msg){
+   // Remove previous messages
+   $("div.alert").remove();
+   // Print new message
+   $("#legend").after('<div class="controls help-block alert alert-success fade in" role="alert">' +
+       '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
+       '<span aria-hidden="true">&times;</span></button>' + htmlEncode(msg)+ '</div>');
+}
+
+function errorMsg(msg){
+   // Remove previous messages
+   $("div.alert").remove();
+   // Print new message
+   $("#legend").after('<div class="controls help-block alert alert-danger fade in" role="alert">' +
+       '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
+       '<span aria-hidden="true">&times;</span></button>' + htmlEncode(msg) + '</div>');
+}
+
+/*
+ * Escape html string
+ */
+function htmlEncode(str){
+  return String(str).replace(/[^\w. ]/gi, function(c){
+     return '&#'+c.charCodeAt(0)+';';
+  });
+}
+
+/*
+ * POST requests
+ */
+function postRequest(url, params) {
+   $.ajax({
+     type: "POST",
+     url: url,
+     data: params,
+     success: function(response) {
+       if (response.msg){
+         if (response.error){
+           errorMsg(response.msg);
+         } else {
+           okMsg(response.msg);
+         }
+
+         if (response.action){
+           if (response.data){
+             // Call to callback
+             window[response.action].apply(null, response.data);
+           }
+         }
+       }
+     }
+   });
+ };
+
