+const generate_checkbox_enabled = (id, enabled, callback) => {
+
+   const $checkbox_enabled = $(`
+      <input 
+         id='${id}'
+         name='enabled' 
+         type="checkbox" 
+         ${enabled ? "checked" : ""} />
+   `);
+
+   // bind check event on checkboxes
+   $checkbox_enabled.change(callback);
+
+   return $checkbox_enabled;
+}
