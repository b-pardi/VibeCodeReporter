+        return false;
+      }
+      if (warnings
+          .getRedFlagWarnings()
+          .stream()
+          .map(Warning::getText)
+          .noneMatch(_subMatcher::matches)) {
+        mismatchDescription.appendText(
+            String.format("No red-flag warnings for host '%s' match", _hostname));
+        return false;
+      }
+      return true;
+    }
+  }
