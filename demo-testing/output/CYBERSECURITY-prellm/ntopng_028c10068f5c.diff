+const apexYFormatterTypes = {
+    no_formatting: { id: "no_formatting", um: null, step: null },
+    number: { id: "number", um: ["", "K", "M", "G", "T"], step: 1000 },
+    bytes: { id: "bytes", um: ["B", "KB", "MB", "GB", "TB"], step: 1024 },
