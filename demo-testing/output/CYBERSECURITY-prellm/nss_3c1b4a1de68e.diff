+/* Appends len copies of c to b */
+SECStatus
+sslBuffer_Fill(sslBuffer *b, PRUint8 c, size_t len)
+{
+    PORT_Assert(b);
+    SECStatus rv = sslBuffer_Grow(b, b->len + len);
+    if (rv != SECSuccess) {
+        return SECFailure;
+    }
+    if (len > 0) {
+        memset(SSL_BUFFER_NEXT(b), c, len);
+    }
