+  @Test
+  public void testEvpnImportPolicyConversion() {
+    Configuration config = parseConfig("arista_bgp_evpn_import_policy");
+    String policyName =
+        config
+            .getDefaultVrf()
+            .getBgpProcess()
+            .getActiveNeighbors()
+            .get(Prefix.parse("2.2.2.2/32"))
+            .getEvpnAddressFamily()
+            .getImportPolicy();
