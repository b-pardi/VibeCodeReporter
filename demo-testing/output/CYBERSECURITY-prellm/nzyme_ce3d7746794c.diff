+import moment from "moment";
+import numeral from "numeral";
+
+function sumValues(sizes) {
+    const vals = Object.values(sizes);
+
+    let total_size = 0;
+    vals.forEach((size) => {
+        total_size += size;
+    });
+
+    return total_size;
+}
+
