+u8 ChooseWildMonIndex_Land(void)
+{
+    u8 pct = Random() % 100;
+    if (pct < 20)
+        return 0;
+    if (pct >= 20 && pct < 40)
+        return 1;
+    if (pct >= 40 && pct < 50)
+        return 2;
+    if (pct >= 50 && pct < 60)
+        return 3;
+    if (pct >= 60 && pct < 70)
+        return 4;
+    if (pct >= 70 && pct < 80)
+        return 5;
+    if (pct >= 80 && pct < 85)
+        return 6;
+    if (pct >= 85 && pct < 90)
+        return 7;
+    if (pct >= 90 && pct < 94)
+        return 8;
+    if (pct >= 94 && pct < 98)
+        return 9;
+    if (pct == 98)
+        return 10;
+    return 11;
+}
