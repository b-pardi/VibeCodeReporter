+static ut64 r_num_from_binary(const char *str) {
+	int i, j;
+	ut64 ret = 0;
+	for (j = 0, i = strlen (str) - 1; i > 0; i--, j++) {
+		if (str[i] == '1') {
+			ret |= (1 << j);
+		} else if (str[i] != '0') {
+			break;
+		}
+	}
+	sscanf (str, "0x%"PFMT64x, &ret);
+	return ret;
+}
+
+R_API ut64 r_num_from_ternary(const char *inp) {
+	if (!inp) {
+		return 0LL;
+	}
+	const char *p;
+	int pos = strlen (inp);
+	ut64 fr = 0;
+	for (p = inp; *p ; p++, pos--) {
+		int n012 = 0;
+		switch (*p) {
+		case '0':
+		case '1':
+		case '2':
+			n012 = *p - '0';
+			fr += n012 * pow (3, pos - 1);
+			break;
+		}
+	}
+	return fr;
+}
