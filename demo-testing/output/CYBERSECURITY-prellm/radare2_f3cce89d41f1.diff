+// 128 bit multiplication result
+static void mult64to128(ut64 op1, ut64 op2, ut64 *hi, ut64 *lo) {
+    ut64 u1 = (op1 & 0xffffffff);
+    ut64 v1 = (op2 & 0xffffffff);
+    ut64 t = (u1 * v1);
+    ut64 w3 = (t & 0xffffffff);
+    ut64 k = (t >> 32);
+
+    op1 >>= 32;
+    t = (op1 * v1) + k;
+    k = (t & 0xffffffff);
+    ut64 w1 = (t >> 32);
+
+    op2 >>= 32;
+    t = (u1 * op2) + k;
+    k = (t >> 32);
+
+    *hi = (op1 * op2) + w1 + k;
+    *lo = (t << 32) + w3;
+}
