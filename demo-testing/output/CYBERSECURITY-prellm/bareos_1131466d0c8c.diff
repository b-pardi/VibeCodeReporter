+def log(message):
+	if debug is True:
+		message = '[%s] %s' % (os.getpid(), message)
+		syslog.syslog(message)
+
+
+def error(message):
+	message = '[%s] %s' % (os.getpid(), message)
+	syslog.syslog(message)
+
+
+# Print the traceback to syslog
+def log_exc():
+	for line in traceback.format_exc().split('\n'):
+		error(line)
+
