+class IterStringIO(io.BufferedIOBase):
+	def __init__(self, iterable):
+		self.iter = itertools.chain.from_iterable(iterable)
+
+	def read(self, n=None):
+		return bytearray(itertools.islice(self.iter, None, n))
+
