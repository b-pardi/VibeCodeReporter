+FifoQueue::FifoQueue(u_int32_t queue_size) {
+  m = new Mutex();
+  size = queue_size;
+  head = tail = 0;
+  cur_items = 0;
+
+  items = (void**)calloc(size, sizeof(void*));
+  if(items == NULL) throw 1;
+}
+
+/* ******************************************* */
+
+FifoQueue::~FifoQueue() {
+  delete m;
+  free(items);
+}
