+def python_2_bytes_compatible(klass):
+    """
+    A class decorator that defines __str__ methods under Python 2.
+    Under Python 3 it does nothing.
+    """
+    if six.PY2:
+        if '__str__' not in klass.__dict__:
+            klass.__str__ = klass.__bytes__
+    return klass