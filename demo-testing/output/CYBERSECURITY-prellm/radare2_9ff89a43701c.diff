+static void graphNodeMove(RAGraph *g, int dir, int speed) {
+	int delta = (dir == 'k')? -1: 1;
+	if (dir == 'H') {
+		return;
+	}
+	if (dir == 'h' || dir == 'l') {
+		// horizontal scroll
+		if (is_mini (g)) {
+			discroll = 0;
+		} else {
+			int delta = (dir == 'l')? 1: -1;
+			move_current_node (g, speed * delta, 0);
+		}
+		return;
+	}
+	RCore *core = NULL;
+	// vertical scroll
+	if (is_mini (g)) {
+		discroll += (delta * speed);
+	} else if (g->is_dis) {
+		r_core_cmdf (core, "so %d", (delta * 4) * speed);
+	} else {
+		move_current_node (g, 0, delta * speed);
+	}
+}
