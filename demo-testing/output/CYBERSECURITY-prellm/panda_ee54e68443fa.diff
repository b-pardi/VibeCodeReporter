+        self._rm = rm_existing_logs
+
+        if log_dir == None:
+            self._log_dir = Path(__file__).parent.absolute().joinpath(self._proc_name)
+        else:
+            self._log_dir = Path(log_dir).joinpath(self._proc_name)
+
+        # Setup logging dir
+        self._log_dir.mkdir(parents=True, exist_ok=True)
