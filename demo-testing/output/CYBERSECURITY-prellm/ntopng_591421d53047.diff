+void PacketStats::incFlagStatsCumulative(u_int8_t flags) {
+  if((flags & TH_SYN) == TH_SYN)                   syn++;
+  if((flags & (TH_SYN|TH_ACK)) == (TH_SYN|TH_ACK)) synack++;
+  if((flags & (TH_FIN|TH_ACK)) == (TH_FIN|TH_ACK)) finack++;
+  if((flags & TH_RST) == TH_RST)                   rst++;
+}
