+        .getTrackActions()
+        .forEach(
+            (trackName, action) -> {
+              TrackMethod trackMethod = trackMethods.get(trackName);
+              if (trackMethod != null && trackMethod.accept(trackMethodEvaluator)) {
+                action.accept(hsrpEvaluator);
+              }
+            });
