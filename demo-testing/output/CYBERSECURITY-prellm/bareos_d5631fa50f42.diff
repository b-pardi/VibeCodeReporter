+class LatexTable(BaseTable):
+
+    def getIndexes(self):
+        result = ''
+        for i in self.columns:
+            result += '\\index[general]{{Platform!{0}!{1}}}'.format(Dist(i).dist, Dist(i).version)
+        return result
+
+    def getHeader(self):
+        result="\\begin{center}\n"
+        result+="\\begin{longtable}{ l "
