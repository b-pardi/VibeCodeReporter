+def get_alg(name):
+    # type: (str) -> TCPAOAlg
+    if name.upper() == "HMAC-SHA-1-96":
+        return TCPAOAlg_HMAC_SHA1()
+    elif name.upper() == "AES-128-CMAC-96":
+        return TCPAOAlg_CMAC_AES()
+    else:
+        raise ValueError("Bad TCP AuthOpt algorithms {}".format(name))
