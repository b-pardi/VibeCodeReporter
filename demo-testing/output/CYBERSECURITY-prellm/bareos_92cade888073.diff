+bool MonitorItemThread::doConnectionTest()
+{
+  int failed = 0;
+  for (int i = 0; i < items.count(); i++) {
+    bool success = items[i]->doconnect();
+    if (success) {
+      items[i]->disconnect();
+    } else {
+      ++failed;
+    }
+  }
+  return failed ? false : true;
+}
