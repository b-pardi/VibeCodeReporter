+        ```
+
+        is equivalent to
+
+        ```
+        @blocking
+        def run_whoami():
+            panda.revert_sync('root')
+            print(panda.run_serial_cmd('whoami'))
+            panda.end_analysis()
+
+        panda.queue_async(run_whoami)
+        ```
+
+        """
+        f = blocking(func)
+        if queue:
+            self.queue_async(f)
+        return f
