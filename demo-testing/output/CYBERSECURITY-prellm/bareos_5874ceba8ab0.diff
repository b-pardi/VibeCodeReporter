+  } else {
+    db_list_ctx jobids_ctx;
+    jcr.db->AccurateGetJobids(&jcr, &jcr.impl->jr, &jobids_ctx);
+    Dmsg1(10, "consolidate candidates:  %s.\n",
+          jobids_ctx.GetAsString().c_str());
+    return jobids_ctx.GetAsString();
+  }
+}
 
