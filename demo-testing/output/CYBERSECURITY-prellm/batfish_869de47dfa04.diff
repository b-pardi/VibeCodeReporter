+
+  @Override
+  public int getStopIndex() {
+    return -1;
+  }
+
+  @Override
+  public String getText() {
+    return _text;
+  }
+
+  @Override
+  public int getTokenIndex() {
+    return 0;
+  }
+
+  @Override
+  public TokenSource getTokenSource() {
+    return null;
+  }
+
+  @Override
