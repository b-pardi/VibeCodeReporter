+static int hashRBinElfSymbol(void * obj) {
+	const RBinElfSymbol *symbol = (const RBinElfSymbol *)obj;
+	int hash = sdb_hash(symbol->name);
+	hash ^= sdb_hash(symbol->type);
+	hash ^= (symbol->offset >> 32);
+	hash ^= (symbol->offset & 0xffffffff);
+
+	return hash;
+}
