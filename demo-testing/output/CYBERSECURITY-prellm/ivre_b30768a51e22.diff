+                self.tables.passive.moreinfo.op('->>')('service_product'),
+                self.tables.passive.moreinfo.op('->>')('service_version'),
+            ]
+        elif use_product:
+            fields = [
+                self.tables.passive.port,
+                self.tables.passive.moreinfo.op('->>')('service_name'),
+                self.tables.passive.moreinfo.op('->>')('service_product'),
+            ]
+        elif use_service:
+            fields = [self.tables.passive.port,
+                      self.tables.passive.moreinfo.op('->>')('service_name')]
+        else:
+            fields = [self.tables.passive.port]
