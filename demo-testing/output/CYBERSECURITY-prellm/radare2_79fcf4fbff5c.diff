+static char *readline(char *buf, size_t *linesz) {
+	char *end = strchr (buf, '\n');
+	if (end) {
+		*end = '\0';
+		*linesz = end - buf;
+		return end + 1;
+	} else {
+		*linesz = strlen (buf);
+		return NULL;
+	}
+}
