+	case 4:
+		status = (bsp_status_t) HAL_MMC_ConfigWideBusOperation(hmmc, SDIO_BUS_WIDE_4B);
+		break;
+	/* Unused, pins are not present on Hydrabus v1
+	case 8:
+		status = (bsp_status_t) HAL_MMC_ConfigWideBusOperation(hmmc, SDIO_BUS_WIDE_8B);
+		break;
+	*/
+	default:
+		status = BSP_ERROR;
+	}
+	return status;
+}
