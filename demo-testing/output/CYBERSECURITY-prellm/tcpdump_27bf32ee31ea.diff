+extern const struct tok edns_opt2str[];
+
+/* print an <EDNS-option> */
+static const u_char *
+eopt_print(netdissect_options *ndo,
+          const u_char *cp)
+{
+	u_int i;
+
+	if (!ND_TTEST_2(cp))
+		return (NULL);
+	i = GET_BE_U_2(cp);
+	cp += 2;
+	ND_PRINT(" %s", tok2str(edns_opt2str, "Opt%u", i));
+	if (!ND_TTEST_2(cp))
+		return (NULL);
+	i = GET_BE_U_2(cp);
+	cp += 2;
+	return (cp + i);
+}
