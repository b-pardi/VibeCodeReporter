+	    j = i;
+	}
+        if(j !== 7)
+	    net += '/' + (16 * (j+1));
+        result.push({
+            "addrpart": addr[i],
+            "net": net,
+        });
+    }
+    return result;
+}
+
+function addr_links(host) {
+    if (host.addr.indexOf(":") == -1) {
