+        .filter(
+            entry -> {
+              LocationInfo info = entry.getValue();
+              return info.isSource() && !toBdd.visit(info.getSourceIps()).isZero();
+            })
+        .map(Entry::getKey)
+        .collect(ImmutableSet.toImmutableSet());
