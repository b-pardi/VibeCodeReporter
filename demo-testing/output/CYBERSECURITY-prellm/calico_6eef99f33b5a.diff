+				CALI_DEBUG("IPIP packet to known Calico host, allow.\n");
+				goto allow;
+			} else {
+				CALI_DEBUG("IPIP packet to unknown dest, drop.\n");
+				ctx->fwd.reason = CALI_REASON_UNAUTH_SOURCE;
+				goto deny;
+			}
