+		return -1;
+	}
+	op->size = 4;
+	const ut32 data = (buf[0] << 24) | (buf[1] << 16) | (buf[2] << 8) | buf[3];
+	if (libps_decode (data, &instr) < 1) {
+		return -1;
+	}
+	char buf_asm[64] = {0};
+	libps_snprint (buf_asm, sizeof (buf_asm), addr, &instr);
+	op->mnemonic = strdup (buf_asm);
+	eprintf ("Mnemonic (%s)\n", buf_asm);
+	return op->size;
+}
