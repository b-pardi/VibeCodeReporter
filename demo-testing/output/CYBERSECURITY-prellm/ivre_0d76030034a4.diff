+_EXPR_INDEX_OF = re.compile(
+    b"<title[^>]*> *(?:index +of|directory +listing +(?:of|for))",
+    re.I,
+)
+_EXPR_FILES = [
+    re.compile(
+        b'<a href="(?P<filename>[^"]+)">[^<]+</a></td><td[^>]*> *'
+        b"(?P<time>[0-9]+-[a-z0-9]+-[0-9]+ [0-9]+:[0-9]+) *"
+        b"</td><td[^>]*> *(?P<size>[^<]+)</td>",
+        re.I,
+    ),
+    re.compile(
+        b'<a href="(?P<filename>[^"]+)">[^<]+</a> *'
+        b"(?P<time>[0-9]+-[a-z0-9]+-[0-9]+ [0-9]+:[0-9]+) *"
+        b"(?P<size>[^ \r\n]+)",
+        re.I,
+    ),
+    re.compile(b'<li><a href="(?P<filename>[^"]+)">(?P=filename)</a>'),
+]
