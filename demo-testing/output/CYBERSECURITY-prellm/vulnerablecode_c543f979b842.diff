+import json
+import requests
+import yaml
+import pytoml as toml
+
+
+def load_yaml(path):
+    with open(path) as f:
+        return yaml.safe_load(f)
+
+
+def load_json(path):
+    with open(path) as f:
+        return json.load(f)
+
+
+def load_toml(path):
+    with open(path) as f:
+        return toml.load(f)
+
+
+def create_etag(data_src, url, etag_key):
+    etag = requests.head(url).headers.get(etag_key)
+    if not etag:
+        return True
+
+    elif url in data_src.config.etags:
+        if data_src.config.etags[url] == etag:
+            return False
+
+    data_src.config.etags[url] = etag
+    return True




