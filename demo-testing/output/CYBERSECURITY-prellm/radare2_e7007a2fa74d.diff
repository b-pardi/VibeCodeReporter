+static HtPP * create_path_to_index(RBuffer *cache_buf, cache_img_t *img, cache_hdr_t *hdr) {
+	HtPP *path_to_idx = ht_pp_new0 ();
+	if (!path_to_idx) {
+		return NULL;
+	}
