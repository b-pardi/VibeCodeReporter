+def expand_cmd_args(args, envvars, pattern=parameter_pattern):
+    pos = 0
+    while True:
+        m = pattern.search(args, pos)
+        if not m:
+            break
+        p = m.group(1)
+        if p in envvars:
+            pv = envvars[p]
+            args = args[:m.start()] + pv + args[m.end():]
+            pos = m.start() + len(pv)
+        else:
+            pos = m.end() + 1
+    return args
