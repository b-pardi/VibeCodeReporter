+        fact['value'] = REDACTED
+    # skipped_abilities
+    for s in redacted.get('skipped_abilities', []):
+        for agentname, ability_list in s.items():
+            for ability in ability_list:
+                ability['ability_name'] = REDACTED
+
+    return redacted
