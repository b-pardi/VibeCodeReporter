+      if(!warning_shown) {
+	ntop->getTrace()->traceEvent(TRACE_WARNING, "Too many results returned from MySQL, reduce query result set");
+	warning_shown = true;
+      }
+    }
+
+    if(limitRows && num >= MYSQL_MAX_NUM_ROWS) break;
+  }
+}
