+class Stopwatch {
+ public:
+  void Start() { start_ = std::chrono::steady_clock::now(); }
+  void Stop() { end_ = std::chrono::steady_clock::now(); }
+  void PrintDurationToStdout()
+  {
+    auto duration = end_ - start_;
