+        << (c % 1000) << "ms";          // format milliseconds
+
+    std::cout << "Duration: " << oss.str() << std::endl;
+  }
+
+ private:
+  std::chrono::time_point<std::chrono::steady_clock> start_;
+  std::chrono::time_point<std::chrono::steady_clock> end_;
+};
