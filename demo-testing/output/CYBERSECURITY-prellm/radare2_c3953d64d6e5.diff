+static const SdbGperf *gperfs_cc[] = {
+	&gperf_cc_arm_16,
+	&gperf_cc_arm_32,
+	&gperf_cc_arm_64,
+	&gperf_cc_avr_8,
+	&gperf_cc_hexagon_32,
+	&gperf_cc_m68k_32,
+	&gperf_cc_mips_32,
+	&gperf_cc_mips_64,
+	&gperf_cc_ppc_32,
+	&gperf_cc_ppc_64,
+	&gperf_cc_riscv_64,
+	&gperf_cc_s390_64,
+	&gperf_cc_sparc_32,
+	&gperf_cc_v850_32,
+	&gperf_cc_x86_16,
