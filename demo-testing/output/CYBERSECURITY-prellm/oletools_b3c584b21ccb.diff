+        """ read into pre-allocated target """
+        n_data = min(len(target), self.size-self.pos)
+        if n_data == 0:
+            return 0
+        target[:n_data] = self.data[self.pos:self.pos+n_data]
+        self.pos += n_data
+        return n_data
+
