+    """Returns True iff the host has the "Honeypot" tag with "SYN+ACK
+    honeypot" info.
+
+    """
+    return any(
+        tag["value"] == "Honeypot" and "SYN+ACK honeypot" in tag.get("info", [])
+        for tag in host.get("tags", [])
+    )
