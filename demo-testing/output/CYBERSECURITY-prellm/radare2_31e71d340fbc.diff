+static bool __isScriptFilename(const char *name) {
+	const char *ext = r_str_lchr (name, '.');
+	if (ext) {
+		ext++;
+		if (!strcmp (ext, "py")
+		||  !strcmp (ext, "js")
+		||  !strcmp (ext, "lua")) {
+			return true;
+		}
+	}
+	return false;
+}
