+	if (*input == '-') {
+		if (errmsg_tmpfile) {
+			r_file_rm (errmsg_tmpfile);
+			errmsg_tmpfile = NULL;
+		}
+		return;
+	}
+	if (!strcmp (input, "errmsg")) {
+		// TODO: support udp, tcp, rap, ...
+#if __UNIX__
+		char *f = r_file_temp ("errmsg");
+		r_cons_printf ("%s\n", f);
+		r_file_rm (f);
+		errmsg_tmpfile = strdup (f);
+		int e = mkfifo (f, 0644);
+		if (e == -1) {
+			perror ("mkfifo");
+		} else {
+			int ff = open (f, O_RDWR);
+			dup2 (ff, 2);
