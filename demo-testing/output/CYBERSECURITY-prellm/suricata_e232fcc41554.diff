+        )
+    else:
+        pairs = (
+            ("src/app-layer-template.c",
+             "src/app-layer-%s.c" % (lower)),
+            ("src/app-layer-template.h",
+             "src/app-layer-%s.h" % (lower)),
+        )
+
+    common_copy_templates(proto, pairs)
