+        {
+            LoadPalette(((u16*)tileset->palettes) + (NUM_PALS_IN_PRIMARY * 16), destOffset, size);
+            sub_80598CC(destOffset, size >> 1);
+        }
+        else
+        {
+            LoadCompressedPalette((u32*)tileset->palettes, destOffset, size);
+            sub_80598CC(destOffset, size >> 1);
+        }
+    }
+}
