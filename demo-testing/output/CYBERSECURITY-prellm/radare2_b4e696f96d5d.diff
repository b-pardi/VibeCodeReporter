+	} else if (!strcmp (op, "ret1")) {
+		r_core_cmdf (core, "wx 12100f00"); // mov v0, 1;ret v0
+	} else if (!strcmp (op, "ret0")) {
+		r_core_cmdf (core, "wx 12000f00"); // mov v0, 0;ret v0
+	} else {
+		eprintf ("Unsupported operation '%s'\n", op);
+		return false;
+	}
+	return true;
+}
