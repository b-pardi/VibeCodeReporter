+	for (i = 0; i < bb->ninstr; i++) {
+		const ut64 prev_pos = r_anal_bb_offset_inst (bb, i);
+		const ut64 op_addr = r_anal_bb_opaddr_i (bb, i);
+		if (prev_pos >= bb->size) {
+			continue;
+		}
+		int buflen = bb->size - prev_pos;
