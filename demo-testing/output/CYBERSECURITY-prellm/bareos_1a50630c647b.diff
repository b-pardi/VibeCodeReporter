+
+    Py_DECREF(tbList);
+    Py_DECREF(emptyString);
+    Py_DECREF(strRetval);
+    Py_DECREF(tracebackModule);
+  } else {
+    error_string = strdup("Unable to import traceback module.");
+  }
+  Py_DECREF(type);
+  Py_XDECREF(value);
+  Py_XDECREF(traceback);
+  printf("%s", error_string);
+
+  free(error_string);
+  exit(1);
+}
