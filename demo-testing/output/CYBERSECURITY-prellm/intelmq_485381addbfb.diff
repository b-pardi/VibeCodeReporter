+                database_dir.mkdir(parents=True, exist_ok=True)
+                with open(database_path, "wb") as database:
+                    database.write(database_data)
+
+            print("Database updated. Reloading affected bots.")
+
+            ctl = IntelMQController()
+            for bot in bots.keys():
+                ctl.bot_reload(bot)
+
