+
+		ut64 mylonglong = r_num_get (NULL, (const char *)buff_hex);
+		ut8 *hex = (ut8 *) ut64_new (mylonglong);
+
+		core->custom->custom_charset = add_rune (core->custom->custom_charset, buff_char, hex);
+		i++;
+	}
+	ls_free (sdbls);
+}
