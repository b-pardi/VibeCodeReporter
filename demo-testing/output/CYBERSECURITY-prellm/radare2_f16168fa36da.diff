+	char *plugin_file_path = r_str_newf (R_JOIN_2_PATHS ("%s", "%s"), plugin_folder, plugin_file);
+
+	if (input[2] == ' ') {
+		load_charset_plugin (core, plugin_file_path);
+	} else {
+		list_avaible_plugins (plugin_folder);
+	}
+	return true;
+}
 
