+class TaskStringIO(Task):
+    file_extension = 'log'
+
+    def __init__(self, task_name, data):
+        self.task_name = task_name
+        self.data = data
+
+    def task_open(self):
+        self.data.seek(0)
+
+    def task_read(self, buf):
+        chunk = self.data.read(len(buf))
+        buf[:len(chunk)] = chunk
+        return len(chunk)
+
