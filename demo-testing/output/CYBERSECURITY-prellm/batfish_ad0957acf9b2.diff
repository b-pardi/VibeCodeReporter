+      if (!(o instanceof EdgeId)) {
+        return false;
+      }
+      EdgeId other = (EdgeId) o;
+      return _tail.equals(other._tail) && _head.equals(other._head);
+    }
+
+    @Override
+    public int hashCode() {
+      return Objects.hash(_tail, _head);
+    }
+
+    @Override
+    public int compareTo(EdgeId o) {
+      return COMPARATOR.compare(this, o);
+    }
+  }
