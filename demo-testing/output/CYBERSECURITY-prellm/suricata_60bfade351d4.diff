+static void PayloadAsHex(const uint8_t *data, uint32_t data_len, char *str, size_t str_len)
+{
+    bool hex = false;
+    for (uint32_t i = 0; i < data_len; i++) {
+        if (NeedsAsHex(data[i])) {
+            char hex_str[4];
+            snprintf(hex_str, sizeof(hex_str), "%s%02X", !hex ? "|" : " ", data[i]);
