+static const char *typeString(ut32 n, int *bits) {
+	*bits = 32;
+	if (n == 12) { // CPU_SUBTYPE_ARM_V7) {
+		return "arm";
+	}
+	if (n == 0x0100000c) { // arm64
+		*bits = 64;
+		is64 = true;
+		return "arm";
+	}
+	if (n == 0x0200000c) { // arm64-32
+		//  TODO: must change bits
+		is64 = false;
+		*bits = 64;
+		return "arm";
+	}
+	return "x86";
+}
