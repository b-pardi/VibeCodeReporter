+void print_bytes(const void *p, size_t len, bool big_endian) {
+	size_t i;
+	for (i = 0; i < len; ++i) {
+		fprintf(patch_file, "%c", ((unsigned char*) p)[big_endian ? (len - i - 1) : i]);
+	}
