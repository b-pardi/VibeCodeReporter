+        "authors": (
+            "Marcin Bury <marcin[at]threat9.com>"  # routersploit module
+        ),
+    }
+
+    cmd = OptString("php", "PHP binary")
+
+    def generate(self):
+        payload = super(Exploit, self).generate()
+
+        cmd = '{} -r "{}"'.format(self.cmd, payload)
+        return cmd

