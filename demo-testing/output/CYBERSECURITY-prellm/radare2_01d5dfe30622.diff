+
+/* Convert a unicode RRune into a UTF-16LE buf */
+R_API int r_utf16le_encode(ut8 *ptr, RRune ch) {
+	if (ch < 0x10000) {
+		ptr[0] = ch & 0xff;
+		ptr[1] = ch >> 8 & 0xff;
+		return 2;
+	}
+	if (ch < 0x110000) {
+		RRune high, low;
+		ch -= 0x10000;
+		high = 0xd800 + (ch >> 10 & 0x3ff);
+		low = 0xdc00 + (ch & 0x3ff);
+		ptr[0] = high & 0xff;
+		ptr[1] = high >> 8 & 0xff;
+		ptr[2] = low & 0xff;
+		ptr[3] = low >> 8 & 0xff;
+		return 4;
+	}
+	return 0;
+}