+"""
+ISOTP Packet
+"""
+
+
+class ISOTP(Packet):
+    name = 'ISOTP'
+    fields_desc = [
+        StrField('data', B"")
+    ]
+
+    def hashret(self):
+        return self.payload.hashret()
+
+    def answers(self, other):
+        if other.__class__ == self.__class__:
+            return self.payload.answers(other.payload)
+        return 0
+
