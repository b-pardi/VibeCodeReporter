+class PandaFile(object):
+	def __init__(self,length):
+		self.pos = 0
+		self.length = length
+		self.closed = False
+		self.mode = "rb"
+		self.name = "/tmp/panda.panda"
+
+	def readable(self):
+		return self.closed
+
+	def read(self, size=1):
+		q = panda.physical_memory_read(self.pos,size)
+		self.pos += size
+		return q
+	
+	def peek(self, size=1):
+		return panda.physical_memory_read(self.pos, size)
+
+	def seek(self, pos, whence=0):
+		if whence == 0:
+			self.pos = pos
+		elif whence == 1:
+			self.pos += pos
+		else:
+			self.pos = self.length - pos
+
+	def tell(self):
+		return self.pos
