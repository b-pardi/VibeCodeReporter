+		bool emu_lazy = r_config_get_i (core->config, "emu.lazy");
+		r_config_set_i (core->config, "emu.lazy", true);
+		r_core_cmd0 (core, "aae");
+		r_config_set_i (core->config, "emu.lazy", emu_lazy);
+	}
+}
