+static void cmd_printmsg(RCore *core, const char *input) {
+	if (!strcmp (input, "ln")) {
+		r_cons_newline ();
+	} else if (!strncmp (input, "ln ", 3)) {
+		r_cons_println (input + 3);
+	} else if (!strncmp (input, " ", 1)) {
