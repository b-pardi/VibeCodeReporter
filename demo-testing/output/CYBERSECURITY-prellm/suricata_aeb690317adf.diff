+        SCReturnInt(0);
+    }
+
+    if (StringParseUint64(&iconf->rss_hf, 0, 0, entry_str) < 0) {
+        SCLogError(SC_ERR_INVALID_VALUE,
+                "RSS hash functions entry for interface %s contain non-numerical "
+                "characters - \"%s\"",
+                iconf->iface, entry_str);
+        SCReturnInt(-EINVAL);
+    }
+
+    SCReturnInt(0);
+}
