+char *Prefs::parseLocalNetworks(char *arg) {
+  struct stat buf;
+  if(stat(arg, &buf) == 0 && S_ISREG(buf.st_mode)) {
+    string res;
+    string line;
+    ifstream fl(arg);
+
+    if(fl.is_open()){
+      /*
+	A file with local networks.
+	Multiple local networks are expressed either using commas and also on multiple lines.
+
