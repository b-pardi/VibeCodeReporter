+		}
+
+		CALI_DEBUG("Received metadata from XDP: %d\n", metadata->flags);
+		return metadata->flags;
+	} else {
+		CALI_DEBUG("Fetching metadata from XDP not supported in this hook\n");
+		return 0;
+	}
+}
