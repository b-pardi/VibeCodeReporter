+#define R_CS_EL_SIZE_SECT_32 0x10
+#define R_CS_EL_SIZE_SYM 0x18
+#define R_CS_EL_SIZE_LSYM 0x24
+#define R_CS_EL_SIZE_LINFO 0x14
