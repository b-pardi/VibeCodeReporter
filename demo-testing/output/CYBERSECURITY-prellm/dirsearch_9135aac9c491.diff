+# Reference: https://stackoverflow.com/questions/46129898/conflict-between-sys-stdin-and-input-eoferror-eof-when-reading-a-line
+def read_stdin():
+    if IS_WINDOWS:
+        tty = "CON:"
+    else:
+        tty = os.ttyname(sys.stdout.fileno())
+
+    buffer = sys.stdin.read()
+    sys.stdin = open(tty)
+    return buffer