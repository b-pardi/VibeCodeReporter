+  private @Nullable NatRulebase getNatRulebase(
+      Package pakij,
+      Map<String, String> packageFiles,
+      ParseVendorConfigurationAnswerElement pvcae,
+      String serverName)
+      throws JsonProcessingException {
+    if (!pakij.hasNatPolicy()) {
