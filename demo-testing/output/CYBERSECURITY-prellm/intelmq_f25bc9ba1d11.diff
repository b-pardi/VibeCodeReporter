+                continue
+            if "extract_files" not in bot["parameters"]:
+                bot["parameters"]["extract_files"] = bot["parameters"]["unzip_attachment"]
+            del bot["parameters"]["unzip_attachment"]
+            changed = True
+    return changed, defaults, runtime
+
