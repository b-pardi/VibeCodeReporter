+  iface = ntop->getInterfaceById(ifid);
+
+  ip_reassignment_enabled = (bool)lua_toboolean(vm, 2);
+  iface->enable_ip_reassignment_alerts(ip_reassignment_enabled);
+
+  lua_pushnil(vm); 
+  
+  return(ntop_lua_return_value(vm, __FUNCTION__, CONST_LUA_OK));
+}
