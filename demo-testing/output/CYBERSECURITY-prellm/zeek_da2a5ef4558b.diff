 using namespace std;
 
+namespace {
+
+void print_escaped(std::string& buf, std::string_view str)
+	{
+	buf.push_back('"');
+	for ( auto c : str )
+		{
+		switch ( c )
+			{
+			default:
+				buf.push_back(c);
+				break;
+			case '\\':
+				buf.push_back('\\');
+				buf.push_back('\\');
+				break;
+			case '\b':
+				buf.push_back('\\');
+				buf.push_back('b');
+				break;
+			case '\f':
+				buf.push_back('\\');
+				buf.push_back('f');
+				break;
+			case '\n':
+				buf.push_back('\\');
+				buf.push_back('n');
+				break;
+			case '\r':
+				buf.push_back('\\');
+				buf.push_back('r');
+				break;
+			case '\t':
+				buf.push_back('\\');
+				buf.push_back('t');
+				break;
+			case '\v':
+				buf.push_back('\\');
+				buf.push_back('v');
+				break;
+			case '"':
+				buf.push_back('\\');
+				buf.push_back('"');
+				break;
+			}
+		}
+	buf.push_back('"');
+	}
+
+	} // namespace
