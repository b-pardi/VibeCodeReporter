+			// eprintf ("thchan_handler no message\n");
+		//	r_th_sem_post (cm->sem);
+		//	r_th_channel_write (core->chan, NULL);
+		//r_th_lock_leave (cm->lock);
+			continue;
+		}
+		char *res = r_core_cmd_str (core, (const char *)cm->msg);
+		free (cm->msg);
+		cm->msg = (ut8 *)res;
+		cm->len = strlen (res) + 1;
+		r_th_channel_post (core->chan, cm);
+		r_th_sem_post (cm->sem);
+	}
+	return 0;
+}
