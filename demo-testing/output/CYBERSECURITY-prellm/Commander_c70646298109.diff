+def adjust_password(password):   # type: (str) -> str
+    if not password:
+        return password
+    if password[0].isalnum():
+        return password
+    for i in range(1, len(password)):
+        if password[i].isalnum():
+            return password[i] + password[1:i] + password[0] + password[i+1:]
+    return 'a' + password
+
