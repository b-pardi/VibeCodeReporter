+class CONNECT(Packet):
+    fields_desc = [
+        LEShortField('station_address', 0),
+        StrFixedLenField('ccp_reserved', b'\xff' * 4, length=4),
+    ]
+
+
+bind_layers(CRO, CONNECT, cmd=0x01)
