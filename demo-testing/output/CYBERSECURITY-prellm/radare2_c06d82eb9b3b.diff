+				RFlagItem *fi = r_flag_get (core->flags, flagname);
+				if (fi) {
+					fi->size = r_num_math (core->num, v);
+				} else {
+					eprintf ("Cannot find flag named '%s'\n", flagname);
+				}
+			}
+		}
+		free (dup);
+	}
+	free (offset);
+	if (IS_MODE_SET (mode)) {
+		r_flag_space_pop (core->flags);
+	}
+}
