+  private void convertEigrpProcess(String procName, EigrpProcessConfiguration processConfig) {
+    processConfig
+        .getVrfs()
+        .forEach(
+            (vrfName, vrfConfig) -> {
+              convertEigrpProcessVrf(procName, processConfig, vrfName, vrfConfig);
+            });
