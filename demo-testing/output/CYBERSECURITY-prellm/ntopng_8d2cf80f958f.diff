+ndpi_serializer* TLSMaliciousSignatureAlert::getAlertJSON(ndpi_serializer* serializer) {
+  Flow *f = getFlow();
+
+  ndpi_serialize_string_string(serializer, "ja3_client_hash", f->getJa3CliHash());
