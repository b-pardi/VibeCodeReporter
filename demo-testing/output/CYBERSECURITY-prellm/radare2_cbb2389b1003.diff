+RAnalEsilOp *esil_get_op (RAnalEsil *esil, const char *op) {
+	r_return_val_if_fail (op && strlen (op) && esil && esil->ops, NULL);
+	char t[128];
+	char *h = sdb_itoa (sdb_hash (op), t, 16);
+	return (RAnalEsilOp *)(size_t)sdb_num_get (esil->ops, h, 0);
+}
