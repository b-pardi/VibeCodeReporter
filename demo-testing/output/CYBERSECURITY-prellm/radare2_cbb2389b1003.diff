+static char *condrets_strtok(char *str, const char tok) {
+	if (!str) {
+		return NULL;
+	}
+	ut32 i = 0;
+	while (1 == 1) {
+		if (!str[i]) {
+			break;
+		}
+		if (str[i] == tok) {
+			str[i] = '\0';
+			return &str[i + 1];
+		}
+		i++;
+	}
+	return NULL;
+}
