+def get_task_from_cr3(task_list, cr3):
+	# for some reason the cr3 we get is 32 bit from PANDA
+	matching = [t for t in task_list.tasks if t.mm and t.mm.pgd and t.mm.pgd & 0xffffffff == cr3 & 0xffffffff]
+	if matching:
+		return matching[0]
+	else:
+		return "[none]"
+
