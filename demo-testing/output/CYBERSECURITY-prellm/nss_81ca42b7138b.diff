+TEST_F(MPITest, MpiInvModLoop) {
+  mp_int a;
+  mp_int m;
+  mp_int c_actual;
+  mp_int c_expect;
+  MP_DIGITS(&a) = 0;
+  MP_DIGITS(&m) = 0;
+  MP_DIGITS(&c_actual) = 0;
+  MP_DIGITS(&c_expect) = 0;
+  ASSERT_EQ(MP_OKAY, mp_init(&a));
