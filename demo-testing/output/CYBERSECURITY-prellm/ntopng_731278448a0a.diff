+int Utils::snappend(char *str, size_t size, const char *tobeappended, const char *separator) {
+  int len = strlen(str), ret;
+
+  ret = snprintf(&str[len], size, "%s%s", (len > 0 && separator) ? separator : "", tobeappended);
+
+  if (ret < 0)
+    return ret;
+
+  return len + ret;
+}
