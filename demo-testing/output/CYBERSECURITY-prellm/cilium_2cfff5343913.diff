+#ifdef ENABLE_IPSEC
+static __always_inline bool is_esp(struct __ctx_buff *ctx, __u16 proto)
+{
+	void *data, *data_end;
+	__u8 protocol = 0;
+	struct ipv6hdr *ip6 __maybe_unused;
+	struct iphdr *ip4 __maybe_unused;
+
+	switch (proto) {
+#ifdef ENABLE_IPV6
