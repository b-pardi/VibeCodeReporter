+R_API bool r_anal_fcn_get_purity(RAnal *anal, RAnalFunction *fcn) {
+	if (!fcn->has_changed) {
+		return fcn->is_pure;
+	}
+	HtUP* ht = ht_up_new (NULL, NULL, NULL);
