+		goto beach;
+	}
+
+	char *digest_hex = r_sign_calc_bbhash (a, fcn);
+	if (!digest_hex) {
+		free (digest_hex);
+		goto beach;
+	}
+	it->hash->bbhash = digest_hex;
+	retval = addItem (a, it);
+beach:
+	r_sign_item_free (it);
+	return retval;
