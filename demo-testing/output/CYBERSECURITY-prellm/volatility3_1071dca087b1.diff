+    def __init__(self, yaml_data):
+        self._yaml_data = yaml_data
+        self._records = self._yaml_data.get('TpiStream', {}).get('Records', {})
+        self._result = {}
+        self._unnamed_counter = 1
+        self._json_data = self._convert()
