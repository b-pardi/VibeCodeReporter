+def get_images(node):
+    """Finds all images associated with node
+
+    Args:
+        node (LinkNode): node used to get links from
+    Returns:
+        links (list): list of links
+    """
+    links = []
+    for child in node.children:
+        link = child.get('src')
+        if link and LinkNode.valid_link(link):
+            links.append(link)
+    return links
