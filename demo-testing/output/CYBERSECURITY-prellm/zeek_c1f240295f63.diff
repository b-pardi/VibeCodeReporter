+// Helper functions to convert dashes to underscores or vice versa.
+static char dash_to_under(char c)
+	{
+	return c == '-' ? '_' : c;
+	}
+
+static char under_to_dash(char c)
+	{
+	return c == '_' ? '-' : c;
+	}
