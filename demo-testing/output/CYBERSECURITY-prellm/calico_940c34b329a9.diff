+#include "../include/bpf.h"
+
+
+struct protoport {
+	__u16 proto;
+	__u16 port;
+};
+
+// Configuration
+struct calico_config {
+	uint32_t debug_on;
+	uint32_t untracked_on;
+	uint32_t pre_dnat_on;
+	uint32_t nat_on;
+};
+
+// Extended map definition for compatibility with iproute2 loader.
+struct bpf_map_def_extended {
+	__u32 type;
+	__u32 key_size;
+	__u32 value_size;
+	__u32 max_entries;
+	__u32 map_flags;
+	__u32 map_id;
+	__u32 pinning_strategy;
+	__u32 unused1;
+	__u32 unused2;
+};
+
+struct bpf_map_def_extended __attribute__((section("maps"))) calico_config = {
+	.type           = BPF_MAP_TYPE_PERCPU_ARRAY,
+	.key_size       = 4,
+	.value_size     = sizeof(struct calico_config),
+	.max_entries    = 1,
+};
+
+// Connection tracking.
+
+struct calico_ct_key {
+	__be32 src_addr; // NBO
+	__be32 dst_addr; // NBO
+    uint16_t src_port;
+    uint16_t dst_port;
+    uint8_t protocol;
+};
+
+enum calico_ct_type {
