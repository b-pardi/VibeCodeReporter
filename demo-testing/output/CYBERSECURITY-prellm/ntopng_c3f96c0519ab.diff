+const get_configuration_data = ($config_table, $button_caller) => {
+
+    // get row data
+    const row_data = $config_table.row($button_caller.parent().parent()).data();
+
+    return {
+        config_id: row_data.id,
+        config_name: row_data.name,
+        config_targets: row_data.targets
+    }
+} 
