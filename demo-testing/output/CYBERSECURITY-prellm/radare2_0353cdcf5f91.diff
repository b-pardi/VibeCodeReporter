+		r_io_submap_set_from (sm, r_io_submap_to (bd) + 1);
+		entry = r_rbtree_cont_node_next (entry);
+	}
+	r_rbtree_cont_insert (bank->submaps, sm, _find_sm_by_vaddr_cb, NULL);
+	r_list_prepend (bank->maprefs, mapref);
+	return true;
