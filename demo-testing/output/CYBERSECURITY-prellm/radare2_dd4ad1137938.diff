+		}
+		args = path_bin + (pp - str) + 1;
+
+		char *path_bin_escaped = r_str_arg_escape (path_bin);
+		int len = strlen (path_bin_escaped);
+
+		path_bin_escaped[len] = ' ';
+		path_bin_escaped[len + 1] = '\0';
+
+		final = r_str_append (path_bin_escaped, args);
+		free (path_bin);
+       }
+
+       return final;
+}
