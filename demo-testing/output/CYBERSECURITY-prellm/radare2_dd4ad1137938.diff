+static char *get_and_escape_path (char *str)
+{
+	char *path_bin = strdup (str);
+	char *final = NULL;
+
+	if (path_bin) {
+		char *p = r_str_lchr (str, '/');
+		char *pp = r_str_tok (p, ' ', -1);
+		char *args;
+
+		if (!pp) {
