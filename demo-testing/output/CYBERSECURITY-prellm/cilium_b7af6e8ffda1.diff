+# define __READ_ONCE(x)		(*(volatile typeof(x) *)&x)
+#endif
+#ifndef __WRITE_ONCE
+# define __WRITE_ONCE(x, v)	(*(volatile typeof(x) *)&x) = (v)
+#endif
