+        }
+        //delete file
+        Optional<FileWrapper> theFile = u1.getByPath(u1.username + "/" + filename).get();
+        Optional<FileWrapper> rootFolder = u1.getByPath(u1.username).get();
+
+        u1.remove(theFile.get(), rootFolder.get()).get();
