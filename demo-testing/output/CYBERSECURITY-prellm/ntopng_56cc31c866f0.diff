+    for (let key in metric.timeseries) {
+	let ts = metric.timeseries[key];
+	timeseries.push({
+	    id: key,
+	    label: ts.label,
+	    raw: true,
+	    avg: false,
+	    perc_95: false,
+	});
+    }
+    return {
+	id, source_type, source, metric, timeseries,
+    };
+};
