+public final class PrefixIpSpaceTest {
+
+  @Test
+  public void testOfDefault() {
+    Prefix prefix = Prefix.strict("0.0.0.0/0");
+    assertEquals(PrefixIpSpace.of(prefix), UniverseIpSpace.INSTANCE);
+  }
+
+  @Test
+  public void testOfIp() {
