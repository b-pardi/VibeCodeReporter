+static char *r_core_cmd_find_subcmd_begin(char *cmd) {
+	int quote = 0;
+	char *p;
+	for (p = cmd; *p; p++) {
+		if (*p == '\\') {
+			p++;
+			if (*p == '\'') {
+				continue;
+			} else if (!*p) {
+				break;
+			}
+		}
+		if (*p == '\'') {
+			quote ^= 1;
+			continue;
+		}
+		if (*p == '`' && !quote) {
+			return p;
+		}
+		if (*p == '$' && *(p + 1) == '(' && !quote) {
+			return p;
+		}
+	}
+	return NULL;
+}
