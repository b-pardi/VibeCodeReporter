+def run(cmd, cwd=None, error_ok=False):
+    print(f"{cmd} # cwd={cwd}")
+    subprocess.run(cmd, cwd=cwd, check=True)
+
+
+def get_size(dir):
+    size = 0
+    for path, dirs, files in os.walk(dir):
+        for f in files:
+            fp = os.path.join(path, f)
+            size += os.path.getsize(fp)
+    return size
+
+
+def sign(path, entitlements, identity):
+    run(
