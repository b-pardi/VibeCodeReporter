+	CRYPTO_set_dynlock_create_callback(nullptr);
+	CRYPTO_set_dynlock_lock_callback(nullptr);
+	CRYPTO_set_dynlock_destroy_callback(nullptr);
+	ssl_mtx_tbl.reset();
+	}
+
+	} // namespace
