+R_API void r_io_bank_init(RIO *io) {
+	r_return_if_fail (io);
+	r_io_bank_fini (io);
+	io->banks = r_id_storage_new (0, UT32_MAX);
+}
+
+R_API void r_io_bank_fini(RIO *io) {
+	r_return_if_fail (io);
+	if (io->banks) {
+		r_id_storage_foreach (io->banks, _bank_free_cb, NULL);
+		r_id_storage_free (io->banks);
+		io->banks = NULL;
+	}
