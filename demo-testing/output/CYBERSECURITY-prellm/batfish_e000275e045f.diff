+
+    // constraint implies !guard => !guard and false branch
+    assertThat(mergeComposed(constraint(v1.not()), branch), equalTo(constraint(v1.not().and(v3))));
+    assertThat(
+        mergeComposed(constraint(v1.not().and(v0)), branch),
