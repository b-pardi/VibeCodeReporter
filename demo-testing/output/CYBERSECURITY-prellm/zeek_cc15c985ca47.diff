+// Expects 'str' to have been made using "%e" scientific notation format string
+static void sn_strip_trailing_zeros(char* str)
+	{
+	char* frac = 0;
+
+	for ( ; ; )
+		{
+		if ( *str == '.' )
+			{
+			frac = str + 1;
+			break;
+			}
+
+		if ( *str == 0 )
+			break;
+
+		++str;
+		}
+
+	if ( ! frac )
+		return;
+
+	char* exp = 0;
+	char* trailing_zeros = 0;
+
+	for ( ; ; )
+		{
+		if ( *frac == 0 )
+			break;
+
+		if ( *frac == 'e' )
+			{
+			exp = frac;
+			break;
+			}
+
+		if ( *frac == '0' )
+			{
+			if ( ! trailing_zeros )
+				trailing_zeros = frac;
+			}
+		else
+			trailing_zeros = 0;
+
+		++frac;
+		}
+
+	if ( trailing_zeros && exp )
+		{
+		for ( ; ; )
+			{
+			*trailing_zeros = *exp;
+
+			if ( *exp == 0 )
+				break;
+
+			++trailing_zeros;
+			++exp;
+			}
+		}
+	}
