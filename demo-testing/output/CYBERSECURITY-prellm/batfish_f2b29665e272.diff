+      if (!byUsage.containsKey(_usage)) {
+        mismatchDescription.appendText(
+            String.format(
+                "File '%s' has no references to structures of type '%s' named '%s' of "
+                    + "usage '%s'",
+                _filename, _type, _structureName, _usage));
+        return false;
+      }
+      return true;
+    }
