+static void
+special(struct parse *p, int ch) {
+	char *oldnext = p->next;
+	char *oldend = p->end;
+	char bracket[16] = {0};
+	int num = 0;
+	switch (ch) {
+	case 'n':
+		ordinary (p, '\n');
+		return;
+	case 't':
+		ordinary (p, '\t');
+		return;
+	case 'r':
+		ordinary (p, '\r');
+		return;
+	case 's':
+		num = 5;
+		memcpy (bracket, "\t\r\n ]", num);
+		break;
+	case 'd':
+		num = 4;
+		memcpy (bracket, "0-9]", num);
+		break;
+	case 'w':
+		num = 4;
+		memcpy (bracket, "a-z]", num);
+		break;
+	default:
+		SETERROR (R_REGEX_INVARG);
+		return;
+	}
+
+	p->next = bracket;
+	p->end = bracket + num;
+
+	p_bracket (p);
+
+	if (p->next == bracket + num) {
+		p->next = oldnext;
+		p->end = oldend;
+	}
