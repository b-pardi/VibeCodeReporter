+          .map(str => {
+            const normalizedString = str.trim();
+
+            if (normalizedString.startsWith('$')) {
+              return normalizedString.slice(1, normalizedString.length).trim();
+            }
+
+            return normalizedString;
+          })
+          .join('\n');
+
+        return normalizedText;
+      },
+    },
+  );
