+    @staticmethod
+    def get_record_field(record, field_name):     # type: (vault.KeeperRecord, str) -> str
+        if isinstance(record, vault.PasswordRecord):
+            if field_name == 'login':
+                return record.login
+            if field_name == 'password':
+                return record.password
+            if field_name == 'url':
+                return record.link
+
+        elif isinstance(record, vault.TypedRecord):
