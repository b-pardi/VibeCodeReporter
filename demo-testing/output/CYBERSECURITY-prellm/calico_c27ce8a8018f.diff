+apiVersion: projectcalico.org/v3
+kind: BGPConfiguration
+metadata:
+  name: default
+spec:
+  serviceClusterIPs:
+  - cidr: 10.96.0.0/12
+  serviceExternalIPs:
+  - cidr: 175.200.0.0/16
+EOF
+""")
+
+            # Assert that a route to the service IP range is present.
+            cluster_cidr = "10.96.0.0/12"
