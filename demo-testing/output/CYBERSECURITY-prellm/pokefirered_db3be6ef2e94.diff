+
+s32 CountDigits(s32 number)
+{
+    if (number / 10 == 0)
+        return 1;
+    else if (number / 100 == 0)
+        return 2;
+    else if (number / 1000 == 0)
+        return 3;
+    else if (number / 10000 == 0)
+        return 4;
+    else if (number / 100000 == 0)
+        return 5;
+    else if (number / 1000000 == 0)
+        return 6;
+    else if (number / 10000000 == 0)
+        return 7;
+    else if (number / 100000000 == 0)
+        return 8;
+    else
+        return 1;
+}
