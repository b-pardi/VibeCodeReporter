+class SWD:
+    """
+    SWD protocol handler
+
+    :example:
+
+    >>> import pyHydrabus
+    >>> swd = pyHydrabus.SWD('/dev/ttyACM0')
+    >>> swd.bus_init()
+    >>> swd.read_dp(0)
