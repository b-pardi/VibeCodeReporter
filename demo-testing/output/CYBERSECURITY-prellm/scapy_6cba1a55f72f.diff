+def is_le(pkt):
+    if hasattr(pkt, "submessageFlags"):
+        end = pkt.submessageFlags & 0b000000001 == 0b000000001
+        return end
+
+    return False
+
+
+def e_flags(pkt: Packet) -> str:
+    if is_le(pkt):
+        return FORMAT_LE
+    else:
+        return FORMAT_BE
