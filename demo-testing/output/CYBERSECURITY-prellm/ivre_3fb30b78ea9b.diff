+def _espace_slash(string):
+    """This function transforms '\\/' in '/' but leaves '\\\\/' unchanged. This
+    is useful to parse regexp from Javascript style (/regexp/).
+
+    """
+    escaping = False
+    new_string = ""
+    for char in string:
+        if not escaping and char == '\\':
+            escaping = True
+        elif escaping and char != '/':
+            new_string += '\\' + char
+            escaping = False
+        else:
+            new_string += char
+            escaping = False
+    return new_string
+
