+void Flow::statusInfosLua(lua_State* vm) const {
+  int i;
+
+  lua_newtable(vm);
+
+  if(status_infos) {
+    for(i=0; i<BITMAP_NUM_BITS; i++) {
+      if(status_map.issetBit(i)) {
+	lua_newtable(vm);
+
