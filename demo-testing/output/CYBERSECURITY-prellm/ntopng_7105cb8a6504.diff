+	  lua_push_str_table_entry(vm, "user_script", status_infos[i].script_key);
+
+	lua_push_int32_table_entry(vm, "score", status_infos[i].score);
+
+	lua_pushinteger(vm, i);
+	lua_insert(vm, -2);
+	lua_settable(vm, -3);
+      }
