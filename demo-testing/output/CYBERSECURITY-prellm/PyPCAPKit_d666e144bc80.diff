+class Analysis:
+    """Analyse report."""
+    @property
+    def info(self):
+        return self._info
+
+    @property
+    def name(self):
+        if self._ptch is None:
+            return 'Unknown'
+        else:
+            return self._ptch.tuple[0]
+
+    @property
+    def protochain(self):
+        return self._ptch
+
+    def __init__(self, info, ptch):
+        self._info = info
+        self._ptch = ptch
+
+    def __str__(self):
+        if self._ptch is None:
+            return self._info
+        else:
+            return f'Analysis({self._ptch.tuple[0]}, info={self._info})'
+
+    def __repr__(self):
+        if self._ptch is None:
+            return 'Analysis()'
+        else:
+            return f'Analysis({self._ptch.tuple[0]})'
+
+
+def analyse(file, length):
+    """Analyse application layer packets."""
+    flag, httpv1 = _analyse_httpv1(file, length)
+    if flag:
