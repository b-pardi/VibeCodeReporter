+static const char *className(RBinDexObj *dex, int idx) {
+	if (idx < 0 || idx >= dex->header.types_size) {
+		return NULL;
+	}
+	DexType dt = dex->types[idx];
+	return getstr (dex, dt.descriptor_id);
+}
