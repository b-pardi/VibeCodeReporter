+    name: Optional[str] = None
+    optional: bool = False
+    package: Optional[str] = None
+
+
+@dataclass
+class ProcessedDefaultElement(InputDefaultElement):
+    parent: Optional[str] = None
+
+    addressing_key: Optional[str] = None
+    result_package: Optional[str] = None




