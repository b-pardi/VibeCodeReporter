+R_API void r_cons_pixel_sets(RConsPixel *p, int x, int y, const char *s) {
+	RRune ch;
+	int cols = 0;
+	int h = 0;
+	const char *e = s + strlen (s);
+	int ll = 0;
+	while (*s) {
+		if (*s == '\n') {
