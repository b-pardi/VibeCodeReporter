+		if (chsz < 1) {
+			chsz = 1;
+		}
+		if (*s != ' ' && *s != '\t') {
+			r_cons_pixel_set (p, x + (ll / 2), y + (h ), 1);
+		}
+		s += chsz;
+		ll++;
+	}
+}
