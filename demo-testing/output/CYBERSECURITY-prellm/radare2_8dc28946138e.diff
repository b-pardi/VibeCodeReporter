+R_API void r_cons_pixel_flush(RConsPixel *p, int sx, int sy) {
+	int rows, cols = r_cons_get_size (&rows);
+	size_t x, y;
+	for (y = 0; y + 4< p->h; y += 4) {
+		for (x = 0; x + 2 < p->w; x += 2) {
+			ut8 *X = p->buf + (x + (y * p->w));
+			int u = 0;
+			u |= (X[0]?$00:0);
+			u |= (X[1]?$01:0);
+			X = p->buf + (x + ((y + 1) * p->w));
+			u |= (X[0]?$10:0);
+			u |= (X[1]?$11:0);
+			X = p->buf + (x + ((y + 2) * p->w));
+			u |= (X[0]?$20:0);
+			u |= (X[1]?$21:0);
+			X = p->buf + (x + ((y + 3) * p->w));
+			u |= (X[0]?$30:0);
+			u |= (X[1]?$31:0);
+			if (u) {
+				RBraile b = r_print_braile (u);
+				int px = sx + (x / 2);
+				int py = sy + (y / 4);
+				if (px >= 0 && px < cols) {
+					if (py >= 0 && py < rows) {
+						r_cons_gotoxy (sx + (x / 2), sy + (y / 4));
+						// r_cons_print (Color_RESET);
+						r_cons_print (b.str);
+					}
+				}
+			}
+		}
+	}
+}




