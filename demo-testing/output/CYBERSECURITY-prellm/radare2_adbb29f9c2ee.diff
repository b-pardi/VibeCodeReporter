+static ut32 convert(ut8 *data, const char *bo) {
+	ut32 n = 0;
+	while (*bo) {
+		int i = *bo - '0';
+		if (i < 1 || i > 4) {
+			break;
+		}
+		n <<= 8;
+		n |= (data[i - 1] & 0xff);
+		bo++;
+	}
+	return n;
+}
