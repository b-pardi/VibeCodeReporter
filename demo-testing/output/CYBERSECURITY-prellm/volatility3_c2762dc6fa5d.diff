+                                    if name.endswith(extension):
+                                        yield "jar:file:" + str(pathlib.Path(base_name)) + "!" + name
+
+                    else:
+                        for extension in constants.ISF_EXTENSIONS:
+                            if filename.endswith(extension):
+                                yield pathlib.Path(base_name).as_uri()
