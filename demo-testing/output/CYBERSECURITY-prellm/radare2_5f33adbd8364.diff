+	if (page < 0) {
+		page = 0;
+	}
+	int count = 0;
+	RListIter *iter;
+	r_list_foreach (list, iter, s) {
+		if (!strncmp (s, "# ", 2)) {
+			count++;
+		}
+		if (count == page) {
+			if (*s == '`') {
+				char *cmd = r_str_ndup (s + 1, strlen (s) -2);
+				char *res = r_core_cmd_str (core, cmd);
+				r_cons_printf ("%s", res);
+				free (res);
+				free (cmd);
+			} else if (r_str_startswith (s, "--gotokey:")) {
+				char *kv = strdup (s + strlen ("--gotokey:"));
+				if (kv[0] && kv[1]) {
+					kv[1] = 0;
+					int k = kv[0];
+					R_FREE (keys[k]);
+					if (kv[2]) {
+						keys[k] = strdup (kv + 2);
+					}
+				}
+				free (kv);
+			} else if (!strncmp (s, "--", 2)) {
+				// directive, do not print
+				
+			} else if (*s == '#') {
+				char *ss = r_str_ss (s, 0);
+				r_cons_printf ("%s\n", ss);
+				free (ss);
+			} else {
+				r_cons_printf ("     %s\n", s);
+			}
+		}
+	}
+}
