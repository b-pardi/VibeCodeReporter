+function delegateTooltips() {
+   $(`span[data-toggle='popover']`).popover({
+      trigger: 'manual',
+      html: true,
+      animation: false,
+  })
+  .on('mouseenter', function () {
+      let self = this;
+      $(this).popover("show");
+      $(".popover").on('mouseleave', function () {
+          $(self).popover('hide');
+      });
+  })
+  .on('mouseleave', function () {
+      let self = this;
+      setTimeout(function () {
+          if (!$('.popover:hover').length) {
+              $(self).popover('hide');
+          }
+      }, 50);
+  });
+}
