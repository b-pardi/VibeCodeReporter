+        elif "DCE_RPC" in services:
+            script["id"] = "dcerpc-ntlm-info"
+        else:
+            utils.LOGGER.warning("Unknown NTLM services: %r", rec.get("source"))
+            script["id"] = "unknown-ntlm-info"
