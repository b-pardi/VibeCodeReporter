+  if((fd = fopen(fname, "rb")) != NULL) {
+    char tmp[1024];
+    size_t n;
+
+    while((n = fread(tmp, 1, sizeof(tmp), fd)) > 0) {
+      if (mg_write(conn, tmp, n) < (int) n) break;
+    }
+
