+std::string BnetSignalToString(int signal)
+{
+  if (bnet_signal_to_text.find(signal) != bnet_signal_to_text.end()) {
+    return bnet_signal_to_text[signal].first;
+  }
+  return std::string("Unknown sig ") + std::to_string(signal);
+}
