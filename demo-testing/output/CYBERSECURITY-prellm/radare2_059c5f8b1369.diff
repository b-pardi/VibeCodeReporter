+static char* regname(uint8_t reg) {
+	switch (reg) {
+	///< cBPF
+	case BPF_REG_A:
+		return "a";
+	case BPF_REG_X:
+		return "x";
+
+	///< eBPF
+	case BPF_REG_R0:
+		return "r0";
+	case BPF_REG_R1:
+		return "r1";
+	case BPF_REG_R2:
+		return "r2";
+	case BPF_REG_R3:
+		return "r3";
+	case BPF_REG_R4:
+		return "r4";
+	case BPF_REG_R5:
+		return "r5";
+	case BPF_REG_R6:
+		return "r6";
+	case BPF_REG_R7:
+		return "r7";
+	case BPF_REG_R8:
+		return "r8";
+	case BPF_REG_R9:
+		return "r9";
+	case BPF_REG_R10:
+		return "r10";
+
+	default:
+		return "0"; // hax
+	}
+}
