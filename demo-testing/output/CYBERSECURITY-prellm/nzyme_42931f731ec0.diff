+                handle.createQuery("SELECT * FROM contacts WHERE bandit_id = :bandit_id AND contact_uuid = :contact_uuid")
+                        .bind("bandit_id", bandit.databaseId())
+                        .bind("contact_uuid", contactUUID)
+                        .mapTo(Contact.class)
+                        .first()
+        );
