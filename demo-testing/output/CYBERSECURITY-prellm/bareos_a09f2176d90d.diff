+// convert bareos message type to syslog log priority
+static int MessageTypeToLogPriority(int message_type)
+{
+  {
+    switch (message_type) {
+      case M_ABORT:
+        return LOG_EMERG;
+      case M_TERM:
+        return LOG_EMERG;
+
+      case M_DEBUG:
+        return LOG_DEBUG;
+      case M_FATAL:
+        return LOG_ALERT;
+
+      case M_ERROR:
+        return LOG_ERR;
+      case M_ERROR_TERM:
+        return LOG_ERR;
+
+      case M_WARNING:
+        return LOG_WARNING;
+
+      case M_INFO:
+        return LOG_INFO;
+      case M_SAVED:
+        return LOG_INFO;
+      case M_NOTSAVED:
+        return LOG_INFO;
+      case M_SKIPPED:
+        return LOG_INFO;
+      case M_MOUNT:
+        return LOG_INFO;
+
+      case M_RESTORED:
+        return LOG_INFO;
+      case M_SECURITY:
+        return LOG_INFO;
+      case M_ALERT:
+        return LOG_INFO;
+      case M_VOLMGMT:
+        return LOG_INFO;
+      case M_AUDIT:
+        return LOG_INFO;
+
+      default:
+        return LOG_ERR;
+    }
+  }
+}
