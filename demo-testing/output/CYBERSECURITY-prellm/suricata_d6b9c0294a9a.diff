+static int DetectKrb5CNameSetup(DetectEngineCtx *de_ctx, Signature *s, const char *arg)
+{
+    DetectBufferSetActiveList(s, g_krb5_cname_buffer_id);
+
+    if (DetectSignatureSetAppProto(s, ALPROTO_KRB5) != 0)
+        return -1;
+
+    return 0;
+}
