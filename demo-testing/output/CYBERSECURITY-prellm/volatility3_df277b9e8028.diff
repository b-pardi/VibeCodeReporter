+    rc, out, err = runvol_plugin("windows.pslist.PsList", image, volatility, python)
+    out = out.lower()
+    assert out.find(b"system") != -1
+    assert out.find(b"csrss.exe") != -1
+    assert out.find(b"svchost.exe") != -1
+    assert out.count(b"\n") > 10
+    assert rc == 0
+    assert rc == 0
+
