+char* trim_entry(char* line)
+{
+    char* backward = NULL;
+
+    // trim leading whitespace
+    while (isspace(*line))
+        line++;
+
+    strtok_s(line, "(", &backward);
+    backward = line + strlen(line);
+
+    // trim trailing whitespace
+    while (isspace(backward[-1]))
+        backward--;
+
+    *backward = '\0';
+    return line;
+}
