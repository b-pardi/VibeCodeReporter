+static inline int lev_byte_diff(RLevBuf *a, RLevBuf *b, ut32 ia, ut32 ib) {
+	if (a->mask) {
+		if ((a->buf[ia] & a->mask[ia]) == (b->buf[ib] & b->mask[ib])) {
+			return 0;
+		}
+	} else {
