+st32 firstsigdigit (ut32 num) {
+	st32 f = -1;
+	st32 b = -1;
+	ut32 forwardmask = 0x80000000;
+	ut32 backwardmask = 0x1;
+	ut32 i;
+	for (i = 0; i < 32; i++ ) {
+		if ( (forwardmask & num) && (f == -1)) {
+			f = i;
+		}
