+static CALI_BPF_INLINE void skb_set_mark(struct __sk_buff *skb, __u32 mark)
+{
+	asm volatile (\
+		"*(u32 *)(%[skb] + %[offset]) = %[mark]" \
+		: /*out*/ : [skb] "r" (skb), [mark] "r" (mark),
