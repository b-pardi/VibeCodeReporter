+static void save_all_panels_settings(RCore *core) {
+	RPanelsRoot *panels_root = core->panels_root;
+	int i;
+	for (i = 0; i < panels_root->n_panels; i++) {
+		RPanels *panels = get_panels (panels_root, i);
+		if (!panels) {
+			continue;
+		}
+		savePanelsLayout (panels, &panels->cfg, true);
+	}
