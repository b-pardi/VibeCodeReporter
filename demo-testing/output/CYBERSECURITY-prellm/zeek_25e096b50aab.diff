+ValTrace::ValTrace(const ValPtr& _v)
+	{
+	v = _v;
+	t = v->GetType();
+
+	switch ( t->Tag() )
+		{
+		case TYPE_LIST:
+			TraceList(cast_intrusive<ListVal>(v));
+			break;
+
+		case TYPE_RECORD:
+			TraceRecord(cast_intrusive<RecordVal>(v));
+			break;
+
+		case TYPE_TABLE:
+			TraceTable(cast_intrusive<TableVal>(v));
+			break;
+
+		case TYPE_VECTOR:
+			TraceVector(cast_intrusive<VectorVal>(v));
+			break;
+
+		default:
+			break;
+		}
+	}
