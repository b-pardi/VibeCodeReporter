+    network: 'str'
+    #: Node number (``-`` separated).
+    node: 'str'
+    #: Socket number (``:`` separated).
+    socket: 'Socket'
+    #: Full address (``:`` separated).
+    addr: 'str'
+
+
+class IPX(Info):
+    """Data model for Internetwork Packet Exchange."""
