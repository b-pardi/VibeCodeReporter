+def ComputerName(self):
+    log.ThugLogging.add_behavior_warn("[WinNTSystemInfo ActiveX] Getting ComputerName")
+    nlen = random.randint(6, 10)
+    computerName = ''.join(
+        random.choice(
+            string.ascii_letters + string.digits) for _ in range(nlen))
+    return computerName
