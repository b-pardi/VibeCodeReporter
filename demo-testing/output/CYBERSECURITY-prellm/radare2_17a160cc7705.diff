+					ELFOBJ* newobj = Elf_(r_bin_elf_new_buf)(newelf, false);
+					struct r_bin_elf_symbol_t *symbol = Elf_(r_bin_elf_get_symbols) (newobj);
+					newobj->g_symbols = NULL;
+					Elf_(r_bin_elf_free)(newobj);
+					r_buf_free (newelf);
+					free (odata);
+					return symbol;
+				}
+				free (data);
+				return NULL;
+			}
+		}
+	}
