+                size = hex(size)
+            count = '/{:d}'.format(b[1]) if bins_type == 'tcachebins' else None
+            chunks = bin_addrs(b, bins_type)
+            for chunk_addr in chunks:
+                if addr == chunk_addr:
+                    labels.append('{:s}[{:s}][{:d}{}]'.format(bins_type, size, chunks.index(addr), count or ''))
+
+    return labels
