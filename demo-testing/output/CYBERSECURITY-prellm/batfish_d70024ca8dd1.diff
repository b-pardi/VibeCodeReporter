+    }
+    if (first == LEVEL_1_2) {
+      return second;
+    }
+    if (second == LEVEL_1_2) {
+      return first;
+    }
+    return null;
+  }
+
+  @Nullable
+  public static IsisLevel union(@Nullable IsisLevel level1, @Nullable IsisLevel level2) {
+    if (level1 == level2) {
+      return level1;
