+    def get_password_strength(password):  # type: (str) -> PasswordStrength
+        length = len(password)
+        caps = 0
+        lower = 0
+        digits = 0
+        symbols = 0
+
+        for ch in password:
+            if ch.isalpha():
+                if ch.isupper():
+                    caps += 1
+                else:
+                    lower += 1
+            elif ch.isdigit():
+                digits += 1
+            else:
+                symbols += 1
+        return PasswordStrength(length=length, caps=caps, lower=lower, digits=digits, symbols=symbols)
