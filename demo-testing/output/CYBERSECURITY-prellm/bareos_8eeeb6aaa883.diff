+             &option_len);
+
+  close(fd);
+  if (ipv6only_option_value < 0) {
+    Emsg1(M_ERROR_TERM, 0, _("Can't extract IPV6ONLY value from socket.\n"));
+  }
+  return ipv6only_option_value;
+}
