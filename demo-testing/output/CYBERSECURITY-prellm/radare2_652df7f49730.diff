+	r_return_if_fail (res);
+	r_cmd_desc_children_foreach (cd, it_cd) {
+		RCmdDesc *child_cd = *it_cd;
+		cmd_desc_remove_from_ht_cmds (cmd, child_cd);
+	}
+}
+
+static void cmd_desc_free(RCmdDesc *cd) {
+	if (!cd) {
