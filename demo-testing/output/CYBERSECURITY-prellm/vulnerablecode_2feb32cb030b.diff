+                summary=xml_data["description"],
+                impacted_package_urls=xml_data["affected_purls"],
+                resolved_package_urls=xml_data["unaffected_purls"],
+                reference_ids=[glsa],
+            )
+            advisory_list.append(advisory)
+        return advisory_list
