+        ) {
+        int proto = atoi(vals[i]);
+        NDPI_BITMASK_ADD(b->clientAllowed, proto);
+      }
+      free(vals[i]);
+    }
+    free(vals);
+  }
+
+  snprintf(key, sizeof(key), "ntopng.prefs.device_policies.server.%u", (u_int) t);
+  rc = ntop->getRedis()->hashKeys(key, &vals);
+
