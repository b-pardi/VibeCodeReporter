+      String[] atoms = s.trim().split(",");
+      checkArgument(atoms.length != 0, ERROR_MESSAGE_TEMPLATE, s);
+      Builder builder = builder();
+      Arrays.stream(atoms).forEach(atom -> processStringAtom(atom.trim(), builder));
+      return builder;
