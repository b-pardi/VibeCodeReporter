+VectorValPtr vector_bool_select(VectorTypePtr vt, const VectorVal* v1,
+                                const VectorVal* v2)
+	{
+	auto v_result = make_intrusive<VectorVal>(std::move(vt));
+
+	for ( unsigned int i = 0; i < v2->Size(); ++i )
