+
+bool Ntop::isValidInterfaceId(int interfaceId) {
+  if((interfaceId < 0)
+     || (interfaceId > num_defined_interfaces)
+     || (getInterfaceById(interfaceId) == NULL)
+     )
+    return(false);
+  else
+    return(true);
